---
/* src/layouts/layout.astro */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  title,
  lang = 'gl',
  description =
    'Web oficial da Sociedade Coral Polifónica de Pontevedra, fundada en 1925.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SCPP</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header lang={lang} />
    
    <main>
      <slot />
    </main>

    <Footer lang={lang} />
  </body>
</html>

<style is:global>
  /* Variables y estilos base mínimos para que el diseño funcione */
  :root {
    --color-principal: #6b1d2f; /* Granate institucional */
    --color-acento: #bd9648;    /* Dorado */
    --color-blanco: #ffffff;
    --color-texto: #2d2d2d;
    --color-gris: #f7f7f7;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Aptos', sans-serif;
    color: var(--color-texto);
    background-color: var(--color-blanco);
    line-height: 1.6;
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
