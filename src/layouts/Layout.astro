---
/* src/layouts/Layout.astro */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PortalAcceptanceGate from '../components/PortalAcceptanceGate.astro';
import PortalReviewStyles from '../components/PortalReviewStyles.astro';
import '../styles/global.css';

const {
  title,
  lang = 'gl',
  description =
    'Web oficial da Sociedade Coral Polifónica de Pontevedra, fundada en 1925.'
} = Astro.props;

const ruta = Astro.url.pathname;
const eZonaPortal = ruta === '/portal' || ruta.startsWith('/portal/');
const eInicioPortal = ruta === '/portal/' || ruta === '/portal';
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | SCPP</title>
    <meta name="description" content={description} />
  </head>
  <body class:list={[eZonaPortal && 'portal-private-body']}>
    {!eZonaPortal && <Header lang={lang} />}

    <main>
      <slot />
    </main>

    {!eZonaPortal && <Footer lang={lang} />}
    {eInicioPortal && <PortalAcceptanceGate />}
    {eZonaPortal && <PortalReviewStyles />}

    {eZonaPortal && (
      <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('.portal-sidebar-footer').forEach((footer) => {
            if (footer.querySelector('.public-site-link')) return;
            const link = document.createElement('a');
            link.className = 'public-site-link';
            link.href = '/';
            link.innerHTML = '<span aria-hidden="true">◎</span><span>Ir á web pública</span>';
            footer.prepend(link);
          });
        });
      </script>
    )}
  </body>
</html>

<style is:global>
  :root {
    --color-principal: #6b1d2f;
    --color-acento: #bd9648;
    --color-blanco: #ffffff;
    --color-texto: #2d2d2d;
    --color-gris: #f7f7f7;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: 'Aptos', 'Calibri', system-ui, sans-serif;
    color: var(--color-texto);
    background-color: var(--color-blanco);
    line-height: 1.6;
  }

  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
