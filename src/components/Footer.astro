---
/* src/components/Footer.astro */
const { lang = 'gl' } = Astro.props;
const year = new Date().getFullYear();

const contactInfo = {
  gl: {
    direccion: 'Enderezo da Sede',
    telefono: 'Teléfono',
    email: 'Email',
    enlaces: 'Ligazóns',
    redes: 'Redes Sociais',
    legal: 'Legal',
  },
  es: {
    direccion: 'Dirección de la Sede',
    telefono: 'Teléfono',
    email: 'Correo',
    enlaces: 'Enlaces',
    redes: 'Redes Sociales',
    legal: 'Legal',
  }
};

const texts = contactInfo[lang] || contactInfo.gl;
---

<footer class="site-footer">
  <div class="container footer-wrapper">
    
    <!-- Bloque Principal -->
    <div class="footer-brand">
      <h3>SCPP</h3>
      <p class="tagline">
        {lang === 'gl' 
          ? 'Fundada en 1925. Cen anos de polifonía e patrimonio cultural en Galicia.' 
          : 'Fundada en 1925. Cien años de polifonía y patrimonio cultural en Galicia.'}
      </p>
    </div>

    <!-- Contacto e Enlaces -->
    <div class="footer-sections">
      
      <!-- Contacto -->
      <div class="footer-section">
        <h4>{texts.direccion}</h4>
        <p>Rúa Luís Braille 40</p>
        <p>36003 Pontevedra</p>
        <p style="margin-top: 0.8rem;">
          <strong>{texts.telefono}:</strong> <a href="tel:+34681254688">681 254 688</a>
        </p>
        <p>
          <strong>{texts.email}:</strong> <a href="mailto:coralpolifonicapontevedra@gmail.com">coralpolifonicapontevedra@gmail.com</a>
        </p>
      </div>

      <!-- Enlaces Útiles -->
      <div class="footer-section">
        <h4>{texts.enlaces}</h4>
        <ul>
          <li><a href="/">Inicio</a></li>
          <li><a href="/acoral">A Coral</a></li>
          <li><a href="/axenda">Axenda</a></li>
          <li><a href="/colabora">Colabora</a></li>
          <li><a href="/portal">Portal</a></li>
        </ul>
      </div>

      <!-- Redes Sociais con SVG -->
      <div class="footer-section">
        <h4>{texts.redes}</h4>
        <div class="social-footer">
          <a href="https://www.facebook.com/PolifonicaPontevedra/" target="_blank" rel="noopener noreferrer" title="Facebook" aria-label="Facebook">
            <svg viewBox="0 0 24 24" class="social-icon-footer"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
          </a>
          <a href="https://www.instagram.com/polifonicapontevedra/" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Instagram">
            <svg viewBox="0 0 24 24" class="social-icon-footer"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@coralpolifonicadepontevedr4676" target="_blank" rel="noopener noreferrer" title="YouTube" aria-label="YouTube">
            <svg viewBox="0 0 24 24" class="social-icon-footer"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

    </div>

  </div>

  <!-- Copyright -->
  <div class="footer-bottom">
    <p>&copy; {year} Sociedade Coral Polifónica de Pontevedra. Todos os dereitos reservados.</p>
    <div class="footer-legal">
      <a href="#">Privacidade</a> | <a href="#">Termos</a> | <a href="#">Cookies</a>
    </div>
  </div>

</footer>

<style>
  .site-footer {
    background-color: var(--color-principal);
    color: var(--color-blanco);
    padding: 4rem 2rem 2rem;
    margin-top: 6rem;
  }

  .footer-wrapper {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .footer-brand h3 {
    color: var(--color-acento);
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 0.9rem;
    opacity: 0.85;
    line-height: 1.6;
  }

  .footer-sections {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-section h4 {
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-acento);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .footer-section p {
    font-size: 0.85rem;
    opacity: 0.8;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .footer-section a {
    color: var(--color-blanco);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .footer-section a:hover {
    opacity: 1;
    color: var(--color-acento);
  }

  .footer-section ul {
    list-style: none;
    padding: 0;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .social-footer {
    display: flex;
    gap: 1rem;
  }

  .social-footer a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .social-footer a:hover {
    background: var(--color-acento);
    transform: scale(1.05);
  }

  .social-icon-footer {
    width: 20px;
    height: 20px;
    fill: var(--color-blanco);
    transition: fill 0.2s ease;
  }

  .social-footer a:hover .social-icon-footer {
    fill: var(--color-principal);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  .footer-legal {
    font-size: 0.75rem;
    opacity: 0.5;
  }

  .footer-legal a {
    color: var(--color-blanco);
    text-decoration: none;
    margin: 0 0.5rem;
    transition: color 0.2s ease;
  }

  .footer-legal a:hover {
    color: var(--color-acento);
  }

  /* Responsivo */
  @media (max-width: 992px) {
    .footer-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-sections {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 576px) {
    .footer-sections {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .footer-brand h3 {
      font-size: 1.5rem;
    }

    .tagline {
      font-size: 0.8rem;
    }

    .social-footer {
      gap: 0.8rem;
    }

    .social-footer a {
      width: 36px;
      height: 36px;
    }

    .social-icon-footer {
      width: 18px;
      height: 18px;
    }
  }
</style>