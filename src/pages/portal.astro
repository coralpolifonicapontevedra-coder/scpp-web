---
/* src/pages/portal.astro */
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Portal de Socios" lang="gl">
  <div class="container portal-page-wrapper">
    <div class="portal-login-card">
      <header class="portal-card-header">
        <span class="portal-lock-icon" aria-hidden="true">🔒</span>
        <h1>Portal de Socios</h1>
        <div class="section-line-center"></div>
        <p>
          Introduce as túas credenciais autorizadas para acceder ao espazo
          interno da Sociedade Coral Polifónica de Pontevedra.
        </p>
      </header>

      <div class="portal-form" id="portal-auth">
        <section id="auth-options" aria-labelledby="auth-title">
          <h2 id="auth-title" class="sr-only">Identificación</h2>

          <button type="button" class="btn-google" id="google-login">
            <span class="google-mark" aria-hidden="true">G</span>
            Continuar con Google
          </button>

          <div class="auth-separator" aria-hidden="true">
            <span>ou</span>
          </div>

          <div class="form-group">
            <label for="email-socio">Correo electrónico</label>
            <input
              type="email"
              id="email-socio"
              name="email"
              required
              autocomplete="email"
              placeholder="Ex. socio@correo.gal"
            />
          </div>

          <button type="button" class="btn-email-link" id="email-link-login">
            Recibir unha ligazón de acceso
          </button>

          <p class="email-help">
            Enviarémosche unha ligazón para entrar sen contrasinal.
          </p>
        </section>

        <section id="authenticated-area" hidden>
          <div class="authenticated-user">
            <div>
              <span>Identificación verificada</span>
              <strong id="authenticated-email"></strong>
            </div>
            <button type="button" id="logout-button">Cambiar conta</button>
          </div>

          <section class="privacy-box" aria-labelledby="privacy-title">
          <h2 id="privacy-title">Protección de datos e condicións de acceso</h2>

          <div class="privacy-text" id="privacy-text" tabindex="0">
            <p>
              Os datos facilitados serán tratados pola Sociedade Coral
              Polifónica de Pontevedra coa finalidade de xestionar o acceso á
              zona privada da web e á aplicación SCPP Xestión, así como as
              comunicacións e funcionalidades internas vinculadas á entidade.
            </p>
            <p>
              O acceso é persoal e non transferible. A persoa usuaria
              comprométese a custodiar as súas credenciais e a empregar a
              información dispoñible exclusivamente para os fins propios da
              Sociedade.
            </p>
            <p>
              A aceptación quedará rexistrada coa data e hora, o correo
              electrónico, a versión do texto legal e os identificadores
              internos da persoa usuaria. Poderá solicitarse a retirada do
              consentimento ou o exercicio dos dereitos correspondentes a
              través da páxina de contacto.
            </p>
          </div>

          <label class="privacy-consent" for="acepta-fines">
            <input
              type="checkbox"
              id="acepta-fines"
              name="aceptaFines"
              required
            />
            <span>
              Lin e acepto as condicións de acceso e o tratamento dos meus
              datos para a xestión da zona privada da web e de SCPP Xestión.
            </span>
          </label>
          </section>

          <button type="button" class="btn-portal-submit" id="portal-submit">
            Aceptar e acceder ao espazo privado
          </button>
        </section>

        <p
          id="portal-message"
          class="portal-message"
          role="status"
          aria-live="polite"
          hidden
        ></p>
      </div>

      <footer class="portal-card-footer">
        <p>
          Es membro da agrupación pero aínda non tes conta?
          <a href="/contacto">Solicita o teu acceso á Xunta Directiva</a>.
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import {
    GoogleAuthProvider,
    getAuth,
    isSignInWithEmailLink,
    onAuthStateChanged,
    sendSignInLinkToEmail,
    signInWithEmailLink,
    signInWithPopup,
    signOut
  } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQD0IkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.useDeviceLanguage();

  const VERSION_TEXTO_LEGAL = 'PRIVACIDADE-WEB-1.0';
  const AMBITO = 'coralpolifonicapontevedra.org';
  const EMAIL_GARDADO = 'scpp-email-acceso';

  const opcionesAcceso = document.querySelector('#auth-options');
  const zonaAutenticada = document.querySelector('#authenticated-area');
  const correoAutenticado = document.querySelector('#authenticated-email');
  const correoInput = document.querySelector('#email-socio');
  const botonGoogle = document.querySelector('#google-login');
  const botonEmail = document.querySelector('#email-link-login');
  const botonSaida = document.querySelector('#logout-button');
  const aceptaInput = document.querySelector('#acepta-fines');
  const mensaxe = document.querySelector('#portal-message');
  const botonAcceso = document.querySelector('#portal-submit');
  const textoLegal = document.querySelector('#privacy-text');

  let enlaceEmailPendente = isSignInWithEmailLink(
    auth,
    window.location.href
  );

  function mostrarMensaxe(texto, tipo = 'erro') {
    if (!(mensaxe instanceof HTMLElement)) return;

    mensaxe.textContent = texto;
    mensaxe.hidden = false;
    mensaxe.dataset.tipo = tipo;
  }

  function ocultarMensaxe() {
    if (!(mensaxe instanceof HTMLElement)) return;

    mensaxe.textContent = '';
    mensaxe.hidden = true;
    delete mensaxe.dataset.tipo;
  }

  function definirBoton(
    boton,
    bloqueado,
    texto
  ) {
    if (!(boton instanceof HTMLButtonElement)) return;

    boton.disabled = bloqueado;
    boton.textContent = texto;
  }

  function actualizarVista(usuario) {
    if (
      !(opcionesAcceso instanceof HTMLElement) ||
      !(zonaAutenticada instanceof HTMLElement) ||
      !(correoAutenticado instanceof HTMLElement)
    ) {
      return;
    }

    const autenticado = Boolean(usuario?.email);
    opcionesAcceso.hidden = autenticado;
    zonaAutenticada.hidden = !autenticado;
    correoAutenticado.textContent = usuario?.email || '';

    if (!autenticado && aceptaInput instanceof HTMLInputElement) {
      aceptaInput.checked = false;
    }
  }

  function limparUrlEnlace() {
    window.history.replaceState(
      {},
      document.title,
      window.location.pathname
    );
  }

  async function completarAccesoPorEmail(email) {
    definirBoton(botonEmail, true, 'Comprobando ligazón…');

    try {
      await signInWithEmailLink(auth, email, window.location.href);
      window.localStorage.removeItem(EMAIL_GARDADO);
      enlaceEmailPendente = false;
      limparUrlEnlace();
      mostrarMensaxe('Identificación verificada correctamente.', 'correcto');
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'A ligazón non é válida ou xa caducou. Solicita unha nova.'
      );
    } finally {
      definirBoton(
        botonEmail,
        false,
        'Recibir unha ligazón de acceso'
      );
    }
  }

  onAuthStateChanged(auth, (usuario) => {
    actualizarVista(usuario);
  });

  botonGoogle?.addEventListener('click', async () => {
    ocultarMensaxe();
    definirBoton(botonGoogle, true, 'Abrindo Google…');

    try {
      const provedor = new GoogleAuthProvider();
      provedor.setCustomParameters({ prompt: 'select_account' });
      await signInWithPopup(auth, provedor);
      mostrarMensaxe('Identificación verificada correctamente.', 'correcto');
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'Non foi posible completar o acceso con Google.'
      );
    } finally {
      definirBoton(botonGoogle, false, 'Continuar con Google');
    }
  });

  botonEmail?.addEventListener('click', async () => {
    ocultarMensaxe();

    if (!(correoInput instanceof HTMLInputElement)) return;

    const email = correoInput.value.trim().toLowerCase();

    if (!email) {
      mostrarMensaxe('Introduce o teu correo electrónico.');
      correoInput.focus();
      return;
    }

    if (enlaceEmailPendente) {
      await completarAccesoPorEmail(email);
      return;
    }

    definirBoton(botonEmail, true, 'Enviando ligazón…');

    try {
      await sendSignInLinkToEmail(auth, email, {
        url: `${window.location.origin}/portal/`,
        handleCodeInApp: true
      });

      window.localStorage.setItem(EMAIL_GARDADO, email);
      mostrarMensaxe(
        'Enviámosche unha ligazón de acceso. Revisa tamén o cartafol de correo non desexado.',
        'correcto'
      );
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'Non foi posible enviar a ligazón. Comproba o correo e inténtao de novo.'
      );
    } finally {
      definirBoton(
        botonEmail,
        false,
        'Recibir unha ligazón de acceso'
      );
    }
  });

  botonSaida?.addEventListener('click', async () => {
    ocultarMensaxe();
    await signOut(auth);
  });

  botonAcceso?.addEventListener('click', async () => {
    ocultarMensaxe();

    if (
      !(aceptaInput instanceof HTMLInputElement) ||
      !(botonAcceso instanceof HTMLButtonElement) ||
      !(textoLegal instanceof HTMLElement)
    ) {
      mostrarMensaxe('Non foi posible iniciar o formulario.');
      return;
    }

    const usuario = auth.currentUser;

    if (!usuario?.email) {
      mostrarMensaxe('É necesario identificarse primeiro.');
      actualizarVista(null);
      return;
    }

    if (!aceptaInput.checked) {
      mostrarMensaxe(
        'É necesario aceptar as condicións para acceder ao espazo privado.'
      );
      aceptaInput.focus();
      return;
    }

    definirBoton(botonAcceso, true, 'Comprobando acceso…');

    try {
      const idToken = await usuario.getIdToken(true);
      const resposta = await fetch('/api/aceptacion', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          idToken,
          accion: 'rexistrarAceptacion',
          version: VERSION_TEXTO_LEGAL,
          textoLegal: textoLegal.innerText.trim(),
          aceptaFines: true,
          ambito: AMBITO
        })
      });

      const resultado = await resposta.json().catch(() => null);

      if (!resposta.ok || !resultado?.ok) {
        throw new Error(
          resultado?.erro ||
          resultado?.detalle ||
          'Non foi posible comprobar o acceso.'
        );
      }

      mostrarMensaxe(
        resultado.mensaxe || 'Aceptación rexistrada correctamente.',
        'correcto'
      );

      if (resultado.redirect) {
        window.location.assign(resultado.redirect);
      }
    } catch (erro) {
      mostrarMensaxe(
        erro instanceof Error
          ? erro.message
          : 'Produciuse un erro ao comprobar o acceso.'
      );
    } finally {
      definirBoton(
        botonAcceso,
        false,
        'Aceptar e acceder ao espazo privado'
      );
    }
  });

  if (enlaceEmailPendente) {
    const emailGardado =
      window.localStorage.getItem(EMAIL_GARDADO) || '';

    if (
      emailGardado &&
      correoInput instanceof HTMLInputElement
    ) {
      correoInput.value = emailGardado;
      completarAccesoPorEmail(emailGardado);
    } else {
      definirBoton(botonEmail, false, 'Completar o acceso');
      mostrarMensaxe(
        'Introduce o mesmo correo ao que recibiches a ligazón para completar o acceso.'
      );
      if (correoInput instanceof HTMLInputElement) {
        correoInput.focus();
      }
    }
  }
</script>

<style>
  .portal-page-wrapper {
    padding-top: 5rem;
    padding-bottom: 7rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 250px);
  }

  .portal-login-card {
    background: var(--color-blanco);
    border: 1px solid var(--color-gris);
    border-radius: 6px;
    padding: 3.5rem;
    max-width: 580px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }

  .portal-card-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .portal-lock-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 1rem;
  }

  .portal-card-header h1 {
    color: var(--color-principal);
    font-size: 2rem;
    font-weight: 700;
  }

  .section-line-center {
    width: 45px;
    height: 2px;
    background-color: var(--color-acento);
    margin: 0.8rem auto 1.2rem;
  }

  .portal-card-header p {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.5;
  }

  .portal-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  #auth-options,
  #authenticated-area {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  #auth-options[hidden],
  #authenticated-area[hidden] {
    display: none;
  }

  .btn-google,
  .btn-email-link {
    width: 100%;
    padding: 0.85rem 1rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      opacity 0.2s ease;
  }

  .btn-google {
    border: 1px solid #c8c8c8;
    background: var(--color-blanco);
    color: #333;
  }

  .btn-google:hover:not(:disabled) {
    border-color: var(--color-principal);
    background: rgba(0, 0, 0, 0.018);
  }

  .google-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    margin-right: 0.55rem;
    border-radius: 50%;
    color: #1a73e8;
    font-weight: 700;
  }

  .btn-email-link {
    border: 1px solid var(--color-principal);
    background: transparent;
    color: var(--color-principal);
  }

  .btn-email-link:hover:not(:disabled) {
    background: color-mix(
      in srgb,
      var(--color-principal) 7%,
      transparent
    );
  }

  .btn-google:disabled,
  .btn-email-link:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  .auth-separator {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: #888;
    font-size: 0.8rem;
  }

  .auth-separator::before,
  .auth-separator::after {
    content: '';
    height: 1px;
    flex: 1;
    background: var(--color-gris);
  }

  .email-help {
    margin: -0.7rem 0 0;
    color: #777;
    font-size: 0.82rem;
    line-height: 1.45;
    text-align: center;
  }

  .authenticated-user {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid #b9dbc1;
    border-radius: 4px;
    background: #f2fbf4;
  }

  .authenticated-user div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .authenticated-user span {
    color: #396842;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .authenticated-user strong {
    color: #24552f;
    font-size: 0.9rem;
    overflow-wrap: anywhere;
  }

  #logout-button {
    flex: 0 0 auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-principal);
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
  }

  #logout-button:hover {
    color: var(--color-acento);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label,
  .privacy-consent {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-texto);
  }

  .label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .forgot-password-link {
    font-size: 0.8rem;
    color: var(--color-principal);
    text-decoration: none;
    font-weight: 600;
  }

  .forgot-password-link:hover {
    color: var(--color-acento);
  }

  .form-group input {
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-gris);
    border-radius: 4px;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-texto);
    background-color: var(--color-blanco);
    transition: border-color 0.2s ease;
  }

  .form-group input:focus,
  .privacy-text:focus {
    outline: 2px solid color-mix(
      in srgb,
      var(--color-principal) 28%,
      transparent
    );
    outline-offset: 2px;
    border-color: var(--color-principal);
  }

  .privacy-box {
    padding: 1.25rem;
    border: 1px solid var(--color-gris);
    border-radius: 5px;
    background: rgba(0, 0, 0, 0.018);
  }

  .privacy-box h2 {
    margin: 0 0 0.9rem;
    color: var(--color-principal);
    font-size: 1rem;
  }

  .privacy-text {
    max-height: 190px;
    overflow-y: auto;
    padding: 0.9rem;
    border: 1px solid var(--color-gris);
    border-radius: 4px;
    background: var(--color-blanco);
    font-size: 0.84rem;
    line-height: 1.55;
    color: #555;
  }

  .privacy-text p {
    margin: 0 0 0.8rem;
  }

  .privacy-text p:last-child {
    margin-bottom: 0;
  }

  .privacy-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 1rem;
    line-height: 1.45;
    cursor: pointer;
  }

  .privacy-consent input {
    width: 1.05rem;
    height: 1.05rem;
    margin-top: 0.12rem;
    flex: 0 0 auto;
    accent-color: var(--color-principal);
  }

  .portal-message {
    margin: 0;
    padding: 0.85rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .portal-message[data-tipo='erro'] {
    border: 1px solid #b42318;
    background: #fff4f2;
    color: #8a1c13;
  }

  .portal-message[data-tipo='correcto'] {
    border: 1px solid #39854a;
    background: #f2fbf4;
    color: #236532;
  }

  .btn-portal-submit {
    display: block;
    width: 100%;
    padding: 0.9rem;
    background-color: var(--color-principal);
    color: var(--color-blanco);
    border: none;
    border-radius: 4px;
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      opacity 0.2s ease;
    margin-top: 0.25rem;
    text-align: center;
  }

  .btn-portal-submit:hover:not(:disabled) {
    background-color: var(--color-acento);
  }

  .btn-portal-submit:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  .portal-card-footer {
    margin-top: 2.5rem;
    border-top: 1px solid var(--color-gris);
    padding-top: 1.5rem;
    text-align: center;
  }

  .portal-card-footer p {
    font-size: 0.85rem;
    color: #777;
    line-height: 1.4;
  }

  .portal-card-footer a {
    color: var(--color-principal);
    text-decoration: none;
    font-weight: 600;
  }

  .portal-card-footer a:hover {
    color: var(--color-acento);
  }

  @media (max-width: 576px) {
    .portal-page-wrapper {
      padding-top: 2.5rem;
      padding-bottom: 4rem;
    }

    .portal-login-card {
      padding: 2rem 1.25rem;
    }

    .label-row {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .authenticated-user {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
