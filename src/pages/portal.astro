---
/* src/pages/portal.astro */
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Portal de Socios" lang="gl">
  <div class="container portal-page-wrapper">
    <div class="portal-login-card">
      <header class="portal-card-header">
        <span class="portal-lock-icon" aria-hidden="true">🔒</span>
        <h1>Portal de Socios</h1>
        <div class="section-line-center"></div>
        <p>
          Introduce as túas credenciais autorizadas para acceder ao espazo
          interno da Sociedade Coral Polifónica de Pontevedra.
        </p>
      </header>

      <div class="portal-form" id="portal-auth">
        <section id="auth-options" aria-labelledby="auth-title">
          <h2 id="auth-title" class="sr-only">Identificación</h2>

          <button type="button" class="btn-google" id="google-login">
            <span class="google-mark" aria-hidden="true">G</span>
            Continuar con Google
          </button>

          <div class="auth-separator" aria-hidden="true">
            <span>ou</span>
          </div>

          <div class="form-group">
            <label for="email-socio">Correo electrónico</label>
            <input
              type="email"
              id="email-socio"
              name="email"
              required
              autocomplete="email"
              placeholder="Ex. socio@correo.gal"
            />
          </div>

          <button type="button" class="btn-email-link" id="email-link-login">
            Recibir unha ligazón de acceso
          </button>

          <p class="email-help">
            Enviarémosche unha ligazón para entrar sen contrasinal.
          </p>
        </section>

        <section id="authenticated-area" hidden>
          <div class="authenticated-user">
            <div>
              <span>Identificación verificada</span>
              <strong id="authenticated-email"></strong>
            </div>
            <button type="button" id="logout-button">Cambiar conta</button>
          </div>

          <section class="privacy-box" aria-labelledby="privacy-title">
          <h2 id="privacy-title">Protección de datos e condicións de acceso</h2>

          <div class="privacy-text" id="privacy-text" tabindex="0">
            <p>
              Os datos facilitados serán tratados pola Sociedade Coral
              Polifónica de Pontevedra coa finalidade de xestionar o acceso á
              zona privada da web e á aplicación SCPP Xestión, así como as
              comunicacións e funcionalidades internas vinculadas á entidade.
            </p>
            <p>
              O acceso é persoal e non transferible. A persoa usuaria
              comprométese a custodiar as súas credenciais e a empregar a
              información dispoñible exclusivamente para os fins propios da
              Sociedade.
            </p>
            <p>
              A aceptación quedará rexistrada coa data e hora, o correo
              electrónico, a versión do texto legal e os identificadores
              internos da persoa usuaria. Poderá solicitarse a retirada do
              consentimento ou o exercicio dos dereitos correspondentes a
              través da páxina de contacto.
            </p>
          </div>

          <label class="privacy-consent" for="acepta-fines">
            <input
              type="checkbox"
              id="acepta-fines"
              name="aceptaFines"
              required
            />
            <span>
              Lin e acepto as condicións de acceso e o tratamento dos meus
              datos para a xestión da zona privada da web e de SCPP Xestión.
            </span>
          </label>
          </section>

          <button type="button" class="btn-portal-submit" id="portal-submit">
            Aceptar e acceder ao espazo privado
          </button>
        </section>

        <section id="private-modules" hidden>
          <header class="modules-header">
            <span>Espazo privado</span>
            <h2>Achegar fotografías</h2>
            <p>
              Envía unha fotografía ao arquivo da Coral. Quedará pendente de
              revisión antes de aparecer na galería pública.
            </p>
          </header>

          <form id="photo-upload-form" class="photo-upload-form">
            <div class="photo-file-field">
              <label for="photo-file">Fotografía</label>
              <input id="photo-file" name="foto" type="file"
                accept="image/jpeg,image/png,image/webp" required />
              <small>JPG, PNG ou WebP. Tamaño máximo: 8 MB.</small>
            </div>
            <div class="form-group">
              <label for="photo-title">Título</label>
              <input id="photo-title" name="titulo" maxlength="120" required />
            </div>
            <div class="form-group">
              <label for="photo-caption">Pé de foto</label>
              <textarea id="photo-caption" name="peFoto" rows="3" maxlength="600"></textarea>
            </div>
            <div class="photo-fields-grid">
              <div class="form-group">
                <label for="photo-date">Data</label>
                <input id="photo-date" name="dataFoto" type="date" />
              </div>
              <div class="form-group">
                <label for="photo-year">Ano aproximado</label>
                <input id="photo-year" name="anoAproximado" type="number"
                  min="1900" max="2100" inputmode="numeric" />
              </div>
              <div class="form-group">
                <label for="photo-place">Lugar</label>
                <input id="photo-place" name="lugar" maxlength="120" />
              </div>
              <div class="form-group">
                <label for="photo-author">Autoría</label>
                <input id="photo-author" name="autoria" maxlength="120" />
              </div>
              <div class="form-group">
                <label for="photo-origin">Procedencia</label>
                <input id="photo-origin" name="procedencia" maxlength="160" />
              </div>
              <div class="form-group">
                <label for="photo-concert">Concerto</label>
                <input id="photo-concert" name="concerto" maxlength="160" />
              </div>
              <div class="form-group">
                <label for="photo-event">Evento</label>
                <input id="photo-event" name="evento" maxlength="160" />
              </div>
            </div>
            <label class="privacy-consent" for="photo-rights">
              <input id="photo-rights" name="confirmaDereitos" type="checkbox" required />
              <span>
                Confirmo que a Coral pode conservar esta imaxe e que dispoño
                de autorización para achegala para a súa posible publicación.
              </span>
            </label>
            <button type="submit" class="btn-portal-submit" id="photo-submit">
              Enviar fotografía para revisión
            </button>
          </form>

          <section id="photo-review-module" class="photo-review-module" hidden>
            <header class="review-header">
              <div>
                <span>Administración</span>
                <h2>Revisión de fotografías</h2>
              </div>
              <button type="button" id="review-refresh" class="review-refresh">
                Actualizar
              </button>
            </header>
            <p class="review-summary">
              <strong id="review-count">0</strong> fotografías pendentes
            </p>
            <div id="review-list" class="review-list"></div>
            <p id="review-empty" class="review-empty" hidden>
              Non hai fotografías pendentes de revisión.
            </p>
          </section>
        </section>

        <p
          id="portal-message"
          class="portal-message"
          role="status"
          aria-live="polite"
          hidden
        ></p>
      </div>

      <footer class="portal-card-footer">
        <p>
          Es membro da agrupación pero aínda non tes conta?
          <a href="/contacto">Solicita o teu acceso á Xunta Directiva</a>.
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import {
    GoogleAuthProvider,
    getAuth,
    isSignInWithEmailLink,
    onAuthStateChanged,
    sendSignInLinkToEmail,
    signInWithEmailLink,
    signInWithPopup,
    signOut
  } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQDOIkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.useDeviceLanguage();

  const VERSION_TEXTO_LEGAL = 'PRIVACIDADE-WEB-1.0';
  const AMBITO = 'coralpolifonicapontevedra.org';
  const EMAIL_GARDADO = 'scpp-email-acceso';

  const opcionesAcceso = document.querySelector('#auth-options');
  const zonaAutenticada = document.querySelector('#authenticated-area');
  const correoAutenticado = document.querySelector('#authenticated-email');
  const correoInput = document.querySelector('#email-socio');
  const botonGoogle = document.querySelector('#google-login');
  const botonEmail = document.querySelector('#email-link-login');
  const botonSaida = document.querySelector('#logout-button');
  const aceptaInput = document.querySelector('#acepta-fines');
  const mensaxe = document.querySelector('#portal-message');
  const botonAcceso = document.querySelector('#portal-submit');
  const textoLegal = document.querySelector('#privacy-text');
  const modulosPrivados = document.querySelector('#private-modules');
  const formularioFoto = document.querySelector('#photo-upload-form');
  const botonFoto = document.querySelector('#photo-submit');
  const moduloRevision = document.querySelector('#photo-review-module');
  const listaRevision = document.querySelector('#review-list');
  const contadorRevision = document.querySelector('#review-count');
  const baleiroRevision = document.querySelector('#review-empty');
  const botonActualizarRevision = document.querySelector('#review-refresh');

  let enlaceEmailPendente = isSignInWithEmailLink(
    auth,
    window.location.href
  );

  function mostrarMensaxe(texto, tipo = 'erro') {
    if (!(mensaxe instanceof HTMLElement)) return;

    mensaxe.textContent = texto;
    mensaxe.hidden = false;
    mensaxe.dataset.tipo = tipo;
  }

  function ocultarMensaxe() {
    if (!(mensaxe instanceof HTMLElement)) return;

    mensaxe.textContent = '';
    mensaxe.hidden = true;
    delete mensaxe.dataset.tipo;
  }

  function definirBoton(
    boton,
    bloqueado,
    texto
  ) {
    if (!(boton instanceof HTMLButtonElement)) return;

    boton.disabled = bloqueado;
    boton.textContent = texto;
  }

  function actualizarVista(usuario) {
    if (
      !(opcionesAcceso instanceof HTMLElement) ||
      !(zonaAutenticada instanceof HTMLElement) ||
      !(correoAutenticado instanceof HTMLElement)
    ) {
      return;
    }

    const autenticado = Boolean(usuario?.email);
    opcionesAcceso.hidden = autenticado;
    zonaAutenticada.hidden = !autenticado;
    correoAutenticado.textContent = usuario?.email || '';

    if (!autenticado && aceptaInput instanceof HTMLInputElement) {
      aceptaInput.checked = false;
    }
    if (!autenticado && modulosPrivados instanceof HTMLElement) {
      modulosPrivados.hidden = true;
    }
  }

  async function mostrarModulosPrivados() {
    if (zonaAutenticada instanceof HTMLElement) zonaAutenticada.hidden = true;
    if (modulosPrivados instanceof HTMLElement) modulosPrivados.hidden = false;
    await cargarFotosRevision();
  }

  function escaparHtml(texto) {
    return String(texto ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  async function solicitarFotosAdmin(accion, datos = {}) {
    const usuario = auth.currentUser;
    if (!usuario?.email) throw new Error('A sesión xa non está activa.');
    const idToken = await usuario.getIdToken(true);
    const resposta = await fetch('/api/fotos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion, ...datos })
    });
    const resultado = await resposta.json().catch(() => null);
    if (!resposta.ok || !resultado?.ok) {
      const erro = Object.assign(
        new Error(resultado?.erro || 'Non foi posible cargar a revisión.'),
        { status: resposta.status }
      );
      throw erro;
    }
    return resultado;
  }

  function debuxarFotosRevision(fotos) {
    if (!(listaRevision instanceof HTMLElement) ||
        !(contadorRevision instanceof HTMLElement) ||
        !(baleiroRevision instanceof HTMLElement)) return;
    contadorRevision.textContent = String(fotos.length);
    baleiroRevision.hidden = fotos.length !== 0;
    listaRevision.innerHTML = fotos.map((foto) => `
      <article class="review-card" data-row-id="${escaparHtml(foto.rowId)}">
        <div class="review-image-wrap">
          ${foto.miniaturaUrl
            ? `<img src="${escaparHtml(foto.miniaturaUrl)}" alt="${escaparHtml(foto.titulo)}" loading="lazy" />`
            : '<div class="review-image-placeholder">Sen miniatura</div>'}
        </div>
        <div class="review-card-body">
          <div class="review-meta">
            <span>${escaparHtml(foto.data || foto.anoAproximado || 'Sen data')}</span>
            <span>${escaparHtml(foto.lugar || 'Lugar sen indicar')}</span>
          </div>
          <label>Título
            <input name="titulo" value="${escaparHtml(foto.titulo)}" maxlength="120" />
          </label>
          <label>Pé de foto
            <textarea name="peFoto" rows="3" maxlength="600">${escaparHtml(foto.peFoto)}</textarea>
          </label>
          <p class="review-details">
            ${escaparHtml(foto.evento || foto.concerto || '')}
            ${foto.autor ? ` · Autoría: ${escaparHtml(foto.autor)}` : ''}
          </p>
          <label>Observacións internas
            <textarea name="observacions" rows="2" maxlength="500">${escaparHtml(foto.observacions)}</textarea>
          </label>
          <label class="review-featured">
            <input type="checkbox" name="destacada" /> Destacar na galería
          </label>
          <div class="review-actions">
            <button type="button" data-review-action="Aprobada">Aprobar e publicar</button>
            <button type="button" data-review-action="Rexeitada" class="reject">Rexeitar</button>
            ${foto.ficheiroUrl
              ? `<a href="${escaparHtml(foto.ficheiroUrl)}" target="_blank" rel="noreferrer">Abrir en Drive</a>`
              : ''}
          </div>
        </div>
      </article>`).join('');
  }

  async function cargarFotosRevision() {
    try {
      const resultado = await solicitarFotosAdmin('listarFotosRevision');
      if (moduloRevision instanceof HTMLElement) moduloRevision.hidden = false;
      debuxarFotosRevision(Array.isArray(resultado.fotos) ? resultado.fotos : []);
    } catch (erro) {
      if (erro instanceof Error && 'status' in erro && erro.status === 403) {
        if (moduloRevision instanceof HTMLElement) moduloRevision.hidden = true;
        return;
      }
      console.error(erro);
    }
  }

  function lerComoBase64(ficheiro) {
    return new Promise((resolve, reject) => {
      const lector = new FileReader();
      lector.onload = () => {
        const resultado = String(lector.result || '');
        resolve(resultado.split(',')[1] || '');
      };
      lector.onerror = () => reject(new Error('Non foi posible ler a fotografía.'));
      lector.readAsDataURL(ficheiro);
    });
  }

  function limparUrlEnlace() {
    window.history.replaceState(
      {},
      document.title,
      window.location.pathname
    );
  }

  async function completarAccesoPorEmail(email) {
    definirBoton(botonEmail, true, 'Comprobando ligazón…');

    try {
      await signInWithEmailLink(auth, email, window.location.href);
      window.localStorage.removeItem(EMAIL_GARDADO);
      enlaceEmailPendente = false;
      limparUrlEnlace();
      mostrarMensaxe('Identificación verificada correctamente.', 'correcto');
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'A ligazón non é válida ou xa caducou. Solicita unha nova.'
      );
    } finally {
      definirBoton(
        botonEmail,
        false,
        'Recibir unha ligazón de acceso'
      );
    }
  }

  onAuthStateChanged(auth, (usuario) => {
    actualizarVista(usuario);
  });

  botonGoogle?.addEventListener('click', async () => {
    ocultarMensaxe();
    definirBoton(botonGoogle, true, 'Abrindo Google…');

    try {
      const provedor = new GoogleAuthProvider();
      provedor.setCustomParameters({ prompt: 'select_account' });
      await signInWithPopup(auth, provedor);
      mostrarMensaxe('Identificación verificada correctamente.', 'correcto');
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'Non foi posible completar o acceso con Google.'
      );
    } finally {
      definirBoton(botonGoogle, false, 'Continuar con Google');
    }
  });

  botonEmail?.addEventListener('click', async () => {
    ocultarMensaxe();

    if (!(correoInput instanceof HTMLInputElement)) return;

    const email = correoInput.value.trim().toLowerCase();

    if (!email) {
      mostrarMensaxe('Introduce o teu correo electrónico.');
      correoInput.focus();
      return;
    }

    if (enlaceEmailPendente) {
      await completarAccesoPorEmail(email);
      return;
    }

    definirBoton(botonEmail, true, 'Enviando ligazón…');

    try {
      await sendSignInLinkToEmail(auth, email, {
        url: `${window.location.origin}/portal/`,
        handleCodeInApp: true
      });

      window.localStorage.setItem(EMAIL_GARDADO, email);
      mostrarMensaxe(
        'Enviámosche unha ligazón de acceso. Revisa tamén o cartafol de correo non desexado.',
        'correcto'
      );
    } catch (erro) {
      console.error(erro);
      mostrarMensaxe(
        'Non foi posible enviar a ligazón. Comproba o correo e inténtao de novo.'
      );
    } finally {
      definirBoton(
        botonEmail,
        false,
        'Recibir unha ligazón de acceso'
      );
    }
  });

  botonSaida?.addEventListener('click', async () => {
    ocultarMensaxe();
    await signOut(auth);
  });

  botonAcceso?.addEventListener('click', async () => {
    ocultarMensaxe();

    if (
      !(aceptaInput instanceof HTMLInputElement) ||
      !(botonAcceso instanceof HTMLButtonElement) ||
      !(textoLegal instanceof HTMLElement)
    ) {
      mostrarMensaxe('Non foi posible iniciar o formulario.');
      return;
    }

    const usuario = auth.currentUser;

    if (!usuario?.email) {
      mostrarMensaxe('É necesario identificarse primeiro.');
      actualizarVista(null);
      return;
    }

    if (!aceptaInput.checked) {
      mostrarMensaxe(
        'É necesario aceptar as condicións para acceder ao espazo privado.'
      );
      aceptaInput.focus();
      return;
    }

    definirBoton(botonAcceso, true, 'Comprobando acceso…');

    try {
      const idToken = await usuario.getIdToken(true);
      const resposta = await fetch('/api/aceptacion', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          idToken,
          accion: 'rexistrarAceptacion',
          version: VERSION_TEXTO_LEGAL,
          textoLegal: textoLegal.innerText.trim(),
          aceptaFines: true,
          ambito: AMBITO
        })
      });

      const resultado = await resposta.json().catch(() => null);

      if (!resposta.ok || !resultado?.ok) {
        throw new Error(
          resultado?.erro ||
          resultado?.detalle ||
          'Non foi posible comprobar o acceso.'
        );
      }

      mostrarMensaxe(
        resultado.mensaxe || 'Aceptación rexistrada correctamente.',
        'correcto'
      );

      mostrarModulosPrivados();
    } catch (erro) {
      mostrarMensaxe(
        erro instanceof Error
          ? erro.message
          : 'Produciuse un erro ao comprobar o acceso.'
      );
    } finally {
      definirBoton(
        botonAcceso,
        false,
        'Aceptar e acceder ao espazo privado'
      );
    }
  });

  formularioFoto?.addEventListener('submit', async (evento) => {
    evento.preventDefault();
    ocultarMensaxe();
    if (!(formularioFoto instanceof HTMLFormElement)) return;

    const usuario = auth.currentUser;
    const ficheiroInput = formularioFoto.elements.namedItem('foto');
    const dereitosInput = formularioFoto.elements.namedItem('confirmaDereitos');
    const ficheiro = ficheiroInput instanceof HTMLInputElement
      ? ficheiroInput.files?.[0] : null;

    if (!usuario?.email || !ficheiro) {
      mostrarMensaxe('Selecciona unha fotografía e comproba a túa sesión.');
      return;
    }
    if (ficheiro.size > 8 * 1024 * 1024) {
      mostrarMensaxe('A fotografía supera o máximo de 8 MB.');
      return;
    }
    if (!(dereitosInput instanceof HTMLInputElement) || !dereitosInput.checked) {
      mostrarMensaxe('É necesario confirmar os dereitos da imaxe.');
      return;
    }

    definirBoton(botonFoto, true, 'Enviando fotografía…');
    try {
      const datosFormulario = new FormData(formularioFoto);
      const base64 = await lerComoBase64(ficheiro);
      const idToken = await usuario.getIdToken(true);
      const resposta = await fetch('/api/fotos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          idToken, nomeFicheiro: ficheiro.name, tipo: ficheiro.type, base64,
          titulo: datosFormulario.get('titulo'),
          peFoto: datosFormulario.get('peFoto'),
          dataFoto: datosFormulario.get('dataFoto'),
          anoAproximado: datosFormulario.get('anoAproximado'),
          lugar: datosFormulario.get('lugar'),
          concerto: datosFormulario.get('concerto'),
          evento: datosFormulario.get('evento'),
          autoria: datosFormulario.get('autoria'),
          procedencia: datosFormulario.get('procedencia'),
          confirmaDereitos: true
        })
      });
      const resultado = await resposta.json().catch(() => null);
      if (!resposta.ok || !resultado?.ok) {
        throw new Error(resultado?.erro || 'Non foi posible enviar a fotografía.');
      }
      formularioFoto.reset();
      mostrarMensaxe(resultado.mensaxe, 'correcto');
    } catch (erro) {
      mostrarMensaxe(erro instanceof Error
        ? erro.message : 'Non foi posible enviar a fotografía.');
    } finally {
      definirBoton(botonFoto, false, 'Enviar fotografía para revisión');
    }
  });

  botonActualizarRevision?.addEventListener('click', async () => {
    definirBoton(botonActualizarRevision, true, 'Actualizando…');
    await cargarFotosRevision();
    definirBoton(botonActualizarRevision, false, 'Actualizar');
  });

  listaRevision?.addEventListener('click', async (evento) => {
    const obxectivo = evento.target;
    if (!(obxectivo instanceof HTMLButtonElement)) return;
    const estado = obxectivo.dataset.reviewAction;
    if (!estado) return;
    const tarxeta = obxectivo.closest('.review-card');
    if (!(tarxeta instanceof HTMLElement)) return;
    const titulo = tarxeta.querySelector('[name="titulo"]');
    const peFoto = tarxeta.querySelector('[name="peFoto"]');
    const observacions = tarxeta.querySelector('[name="observacions"]');
    const destacada = tarxeta.querySelector('[name="destacada"]');

    obxectivo.disabled = true;
    try {
      const resultado = await solicitarFotosAdmin('actualizarRevisionFoto', {
        rowId: tarxeta.dataset.rowId,
        estado,
        titulo: titulo instanceof HTMLInputElement ? titulo.value : '',
        peFoto: peFoto instanceof HTMLTextAreaElement ? peFoto.value : '',
        observacions: observacions instanceof HTMLTextAreaElement
          ? observacions.value : '',
        destacada: destacada instanceof HTMLInputElement && destacada.checked
      });
      tarxeta.remove();
      await cargarFotosRevision();
      mostrarMensaxe(resultado.mensaxe, 'correcto');
    } catch (erro) {
      mostrarMensaxe(erro instanceof Error
        ? erro.message : 'Non foi posible revisar a fotografía.');
      obxectivo.disabled = false;
    }
  });

  if (enlaceEmailPendente) {
    const emailGardado =
      window.localStorage.getItem(EMAIL_GARDADO) || '';

    if (
      emailGardado &&
      correoInput instanceof HTMLInputElement
    ) {
      correoInput.value = emailGardado;
      completarAccesoPorEmail(emailGardado);
    } else {
      definirBoton(botonEmail, false, 'Completar o acceso');
      mostrarMensaxe(
        'Introduce o mesmo correo ao que recibiches a ligazón para completar o acceso.'
      );
      if (correoInput instanceof HTMLInputElement) {
        correoInput.focus();
      }
    }
  }
</script>

