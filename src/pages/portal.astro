---
/* src/pages/portal.astro */
import BaseLayout from '../layouts/Layout.astro';
import PortalSidebar from '../components/PortalSidebar.astro';
---

<BaseLayout title="Portal do Coralista" lang="gl">
  <div id="portal-sidebar-container" class="portal-sidebar-container" hidden>
    <PortalSidebar active="inicio" logoutId="portal-sidebar-logout" />
  </div>

  <main id="portal-shell" class="portal-shell">
    <section class="portal-hero" aria-labelledby="portal-title">
      <div class="portal-intro">
        <span class="portal-eyebrow">Espazo privado</span>
        <h1 id="portal-title">Portal do Coralista</h1>
        <p class="portal-lead">
          Un punto de encontro para consultar a información interna da Coral,
          acceder ao repertorio, coñecer os próximos concertos e colaborar no
          arquivo fotográfico da Sociedade.
        </p>

        <div class="portal-feature-grid" aria-label="Contidos do portal">
          <article><span>01</span><strong>Concertos</strong><p>Convocatorias, horarios, programa e información práctica.</p></article>
          <article><span>02</span><strong>Repertorio</strong><p>Partituras, audios por corda, vídeos e notas de traballo.</p></article>
          <article><span>03</span><strong>Ensaios</strong><p>Calendario, avisos, asistencia e materiais de preparación.</p></article>
          <article><span>04</span><strong>Galería</strong><p>Consulta, achega e revisión das fotografías da Coral.</p></article>
          <article><span>05</span><strong>Documentación</strong><p>Actas, estatutos, normativa e información interna.</p></article>
          <article><span>06</span><strong>Perfil</strong><p>Datos persoais, voz, contacto e preferencias do usuario.</p></article>
        </div>
      </div>

      <aside class="portal-access-card" aria-labelledby="auth-title">
        <div id="auth-options">
          <span class="access-kicker">Acceso reservado</span>
          <h2 id="auth-title">Identifícate para continuar</h2>
          <p>
            Emprega a conta autorizada pola Sociedade Coral Polifónica de
            Pontevedra.
          </p>

          <button type="button" class="btn-google" id="google-login">
            <span aria-hidden="true">G</span>
            Continuar con Google
          </button>

          <div class="auth-separator" aria-hidden="true"><span>ou</span></div>

          <label for="email-socio">Correo electrónico</label>
          <input
            type="email"
            id="email-socio"
            autocomplete="email"
            placeholder="nome@correo.gal"
          />

          <button type="button" class="btn-email" id="email-link-login">
            Recibir unha ligazón de acceso
          </button>
          <small>Non necesitas contrasinal. Enviarémosche unha ligazón ao correo.</small>
        </div>

        <div id="session-status" hidden>
          <span class="access-kicker">Sesión iniciada</span>
          <h2>Comprobando o teu acceso</h2>
          <p id="authenticated-email"></p>
          <div class="loading-line" aria-hidden="true"></div>
        </div>

        <p id="portal-message" class="portal-message" role="status" aria-live="polite" hidden></p>

        <footer>
          <p>
            Es membro da agrupación pero aínda non tes acceso?
            <a href="/contacto">Solicítao á Xunta Directiva</a>.
          </p>
        </footer>
      </aside>
    </section>

    <section id="private-dashboard" class="private-dashboard" hidden aria-labelledby="dashboard-title">
      <div class="private-layout">
        <div class="dashboard-main">
          <header class="dashboard-header">
        <div>
          <span class="portal-eyebrow">Portal do Coralista</span>
          <h2 id="dashboard-title">Benvido ao espazo privado</h2>
          <p>
            Desde aquí poderás acceder aos distintos servizos internos da Coral.
          </p>
        </div>
        <div class="session-card">
          <span>Conta identificada</span>
          <strong id="dashboard-email"></strong>
          <button type="button" id="logout-button">Pechar sesión</button>
        </div>
      </header>

      <div class="dashboard-grid">
        <a class="module-card module-active" href="/portal/fotos/">
          <span class="module-number">01</span>
          <div><strong>Achegar fotografías</strong><p>Envía novas imaxes ao arquivo da Coral para a súa revisión.</p></div>
          <span class="module-arrow" aria-hidden="true">→</span>
        </a>

        <a id="photo-review-link" class="module-card module-admin" href="/portal/revision-fotos/" hidden>
          <span class="module-number">02</span>
          <div><strong>Revisión de fotografías</strong><p>Aproba, rexeita e completa a información das imaxes recibidas.</p></div>
          <span class="module-arrow" aria-hidden="true">→</span>
        </a>

        <article class="module-card module-soon">
          <span class="module-number">03</span>
          <div><strong>Concertos</strong><p>Convocatorias, horarios, programa, uniforme e desprazamentos.</p></div>
          <span class="module-state">Próximamente</span>
        </article>

        <article class="module-card module-soon">
          <span class="module-number">04</span>
          <div><strong>Repertorio</strong><p>Partituras, audios, vídeos e notas para preparar cada obra.</p></div>
          <span class="module-state">Próximamente</span>
        </article>

        <article class="module-card module-soon">
          <span class="module-number">05</span>
          <div><strong>Ensaios</strong><p>Calendario, avisos, asistencia e materiais de traballo.</p></div>
          <span class="module-state">Próximamente</span>
        </article>

        <article class="module-card module-soon">
          <span class="module-number">06</span>
          <div><strong>Documentación</strong><p>Estatutos, actas, normativa e documentación interna.</p></div>
          <span class="module-state">Próximamente</span>
        </article>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div id="privacy-modal" class="privacy-modal" hidden>
    <div class="privacy-backdrop"></div>
    <section class="privacy-dialog" role="dialog" aria-modal="true" aria-labelledby="privacy-title">
      <span class="access-kicker">Primeiro acceso</span>
      <h2 id="privacy-title">Protección de datos e condicións de acceso</h2>
      <div class="privacy-text" id="privacy-text" tabindex="0">
        <p>
          Os datos facilitados serán tratados pola Sociedade Coral Polifónica de
          Pontevedra coa finalidade de xestionar o acceso á zona privada da web e
          á aplicación SCPP Xestión, así como as comunicacións e funcionalidades
          internas vinculadas á entidade.
        </p>
        <p>
          O acceso é persoal e non transferible. A persoa usuaria comprométese a
          custodiar as súas credenciais e a empregar a información dispoñible
          exclusivamente para os fins propios da Sociedade.
        </p>
        <p>
          A aceptación quedará rexistrada coa data e hora, o correo electrónico,
          a versión do texto legal e os identificadores internos da persoa
          usuaria. Poderá solicitarse a retirada do consentimento ou o exercicio
          dos dereitos correspondentes a través da páxina de contacto.
        </p>
      </div>

      <label class="privacy-consent" for="acepta-fines">
        <input id="acepta-fines" type="checkbox" />
        <span>
          Lin e acepto as condicións de acceso e o tratamento dos meus datos para
          a xestión da zona privada da web e de SCPP Xestión.
        </span>
      </label>

      <p id="privacy-message" class="privacy-message" role="status"
        aria-live="polite" hidden></p>

      <div class="privacy-actions">
        <button type="button" class="btn-secondary" id="privacy-logout">Cancelar e saír</button>
        <button type="button" class="btn-primary" id="portal-submit">Aceptar e continuar</button>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import {
    GoogleAuthProvider,
    getAuth,
    isSignInWithEmailLink,
    onAuthStateChanged,
    sendSignInLinkToEmail,
    signInWithEmailLink,
    signInWithPopup,
    signOut
  } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQDOIkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.useDeviceLanguage();

  const VERSION_TEXTO_LEGAL = 'PRIVACIDADE-WEB-1.0';
  const AMBITO = 'coralpolifonicapontevedra.org';
  const EMAIL_GARDADO = 'scpp-email-acceso';

  const authOptions = document.querySelector('#auth-options');
  const sessionStatus = document.querySelector('#session-status');
  const authenticatedEmail = document.querySelector('#authenticated-email');
  const dashboardEmail = document.querySelector('#dashboard-email');
  const dashboard = document.querySelector('#private-dashboard');
  const portalShell = document.querySelector('#portal-shell');
  const sidebarContainer = document.querySelector('#portal-sidebar-container');
  const privacyModal = document.querySelector('#privacy-modal');
  const privacyText = document.querySelector('#privacy-text');
  const privacyMessage = document.querySelector('#privacy-message');
  const consent = document.querySelector('#acepta-fines');
  const message = document.querySelector('#portal-message');
  const emailInput = document.querySelector('#email-socio');
  const googleButton = document.querySelector('#google-login');
  const emailButton = document.querySelector('#email-link-login');
  const acceptButton = document.querySelector('#portal-submit');
  const logoutButton = document.querySelector('#logout-button');
  const sidebarLogout = document.querySelector('#portal-sidebar-logout');
  const privacyLogout = document.querySelector('#privacy-logout');
  const reviewLink = document.querySelector('#photo-review-link');

  let emailLinkPending = isSignInWithEmailLink(auth, window.location.href);
  let checkingUser = false;

  function showMessage(text, type = 'erro') {
    if (!(message instanceof HTMLElement)) return;
    message.textContent = text;
    message.dataset.type = type;
    message.hidden = false;
  }

  function hideMessage() {
    if (!(message instanceof HTMLElement)) return;
    message.textContent = '';
    message.hidden = true;
    delete message.dataset.type;
  }

  function showPrivacyMessage(text) {
    if (!(privacyMessage instanceof HTMLElement)) return;
    privacyMessage.textContent = text;
    privacyMessage.hidden = false;
  }

  function hidePrivacyMessage() {
    if (!(privacyMessage instanceof HTMLElement)) return;
    privacyMessage.textContent = '';
    privacyMessage.hidden = true;
  }

  function setButton(button, disabled, text) {
    if (!(button instanceof HTMLButtonElement)) return;
    button.disabled = disabled;
    button.textContent = text;
  }

  function cleanEmailLinkUrl() {
    window.history.replaceState({}, document.title, window.location.pathname);
  }

  function showSignedOut() {
    if (authOptions instanceof HTMLElement) authOptions.hidden = false;
    if (sessionStatus instanceof HTMLElement) sessionStatus.hidden = true;
    if (dashboard instanceof HTMLElement) dashboard.hidden = true;
    if (portalShell instanceof HTMLElement) portalShell.classList.remove('private-active');
    if (sidebarContainer instanceof HTMLElement) sidebarContainer.hidden = true;
    if (privacyModal instanceof HTMLElement) privacyModal.hidden = true;
    document.body.classList.remove('modal-open');
    if (reviewLink instanceof HTMLElement) reviewLink.hidden = true;
  }

  function showChecking(email) {
    if (authOptions instanceof HTMLElement) authOptions.hidden = true;
    if (sessionStatus instanceof HTMLElement) sessionStatus.hidden = false;
    if (authenticatedEmail instanceof HTMLElement) authenticatedEmail.textContent = email;
    if (dashboard instanceof HTMLElement) dashboard.hidden = true;
    if (portalShell instanceof HTMLElement) portalShell.classList.remove('private-active');
    if (sidebarContainer instanceof HTMLElement) sidebarContainer.hidden = true;
  }

  function showPrivacyModal() {
    if (privacyModal instanceof HTMLElement) privacyModal.hidden = false;
    document.body.classList.add('modal-open');
    if (consent instanceof HTMLInputElement) consent.checked = false;
    hidePrivacyMessage();
  }

  function hidePrivacyModal() {
    if (privacyModal instanceof HTMLElement) privacyModal.hidden = true;
    document.body.classList.remove('modal-open');
  }

  async function requestAcceptance(action, extra = {}) {
    const user = auth.currentUser;
    if (!user?.email) throw new Error('A sesión xa non está activa.');
    const idToken = await user.getIdToken(true);
    const response = await fetch('/api/aceptacion', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion: action, version: VERSION_TEXTO_LEGAL, ...extra })
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result?.ok) {
      throw new Error(result?.erro || result?.detalle || 'Non foi posible comprobar o acceso.');
    }
    return result;
  }

  async function requestPhotoAdmin() {
    const user = auth.currentUser;
    if (!user?.email) return false;
    const idToken = await user.getIdToken(true);
    const response = await fetch('/api/fotos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion: 'listarFotosRevision' })
    });
    const result = await response.json().catch(() => null);
    return response.ok && result?.ok === true;
  }

  async function showDashboard(user) {
    hidePrivacyModal();
    if (authOptions instanceof HTMLElement) authOptions.hidden = true;
    if (sessionStatus instanceof HTMLElement) sessionStatus.hidden = true;
    if (dashboard instanceof HTMLElement) dashboard.hidden = false;
    if (portalShell instanceof HTMLElement) portalShell.classList.add('private-active');
    if (sidebarContainer instanceof HTMLElement) sidebarContainer.hidden = false;
    if (dashboardEmail instanceof HTMLElement) dashboardEmail.textContent = user.email || '';
    if (reviewLink instanceof HTMLElement) {
      reviewLink.hidden = true;
      try {
        reviewLink.hidden = !(await requestPhotoAdmin());
      } catch {
        reviewLink.hidden = true;
      }
    }
  }

  async function checkCurrentUser(user) {
    if (checkingUser) return;
    checkingUser = true;
    hideMessage();
    showChecking(user.email || '');
    try {
      const result = await requestAcceptance('comprobarAceptacion');
      if (result.aceptacionVixente === true) {
        await showDashboard(user);
      } else {
        showPrivacyModal();
      }
    } catch (error) {
      await signOut(auth);
      showMessage(error instanceof Error ? error.message : 'Non foi posible comprobar o acceso.');
    } finally {
      checkingUser = false;
    }
  }

  async function completeEmailAccess(email) {
    setButton(emailButton, true, 'Comprobando ligazón…');
    try {
      await signInWithEmailLink(auth, email, window.location.href);
      window.localStorage.removeItem(EMAIL_GARDADO);
      emailLinkPending = false;
      cleanEmailLinkUrl();
    } catch (error) {
      console.error(error);
      showMessage('A ligazón non é válida ou xa caducou. Solicita unha nova.');
    } finally {
      setButton(emailButton, false, 'Recibir unha ligazón de acceso');
    }
  }

  onAuthStateChanged(auth, async (user) => {
    if (!user?.email) {
      showSignedOut();
      return;
    }
    await checkCurrentUser(user);
  });

  googleButton?.addEventListener('click', async () => {
    hideMessage();
    setButton(googleButton, true, 'Abrindo Google…');
    try {
      const provider = new GoogleAuthProvider();
      provider.setCustomParameters({ prompt: 'select_account' });
      await signInWithPopup(auth, provider);
    } catch (error) {
      console.error(error);
      showMessage('Non foi posible completar o acceso con Google.');
    } finally {
      setButton(googleButton, false, 'Continuar con Google');
    }
  });

  emailButton?.addEventListener('click', async () => {
    hideMessage();
    if (!(emailInput instanceof HTMLInputElement)) return;
    const email = emailInput.value.trim().toLowerCase();
    if (!email) {
      showMessage('Introduce o teu correo electrónico.');
      emailInput.focus();
      return;
    }
    if (emailLinkPending) {
      await completeEmailAccess(email);
      return;
    }
    setButton(emailButton, true, 'Enviando ligazón…');
    try {
      await sendSignInLinkToEmail(auth, email, {
        url: `${window.location.origin}/portal/`,
        handleCodeInApp: true
      });
      window.localStorage.setItem(EMAIL_GARDADO, email);
      showMessage('Enviámosche unha ligazón de acceso. Revisa tamén o correo non desexado.', 'correcto');
    } catch (error) {
      console.error(error);
      showMessage('Non foi posible enviar a ligazón. Comproba o correo e inténtao de novo.');
    } finally {
      setButton(emailButton, false, 'Recibir unha ligazón de acceso');
    }
  });

  acceptButton?.addEventListener('click', async () => {
    hideMessage();
    hidePrivacyMessage();
    if (!(consent instanceof HTMLInputElement) || !consent.checked) {
      showPrivacyMessage('É necesario aceptar as condicións para acceder ao espazo privado.');
      consent?.focus();
      return;
    }
    if (!(privacyText instanceof HTMLElement)) return;
    setButton(acceptButton, true, 'Rexistrando aceptación…');
    try {
      await requestAcceptance('rexistrarAceptacion', {
        textoLegal: privacyText.innerText.trim(),
        aceptaFines: true,
        ambito: AMBITO
      });
      const user = auth.currentUser;
      if (user) await showDashboard(user);
    } catch (error) {
      showPrivacyMessage(
        error instanceof Error
          ? error.message
          : 'Non foi posible rexistrar a aceptación.'
      );
    } finally {
      setButton(acceptButton, false, 'Aceptar e continuar');
    }
  });

  logoutButton?.addEventListener('click', () => signOut(auth));
  sidebarLogout?.addEventListener('click', () => signOut(auth));
  privacyLogout?.addEventListener('click', () => signOut(auth));

  if (emailLinkPending) {
    const savedEmail = window.localStorage.getItem(EMAIL_GARDADO);
    if (savedEmail) {
      completeEmailAccess(savedEmail);
    } else if (emailInput instanceof HTMLInputElement) {
      emailInput.focus();
      showMessage('Introduce o correo no que recibiches a ligazón para completar o acceso.', 'aviso');
    }
  }
</script>

<style>
  :global(body.modal-open) { overflow: hidden; }
  .portal-shell { max-width: 1240px; margin: 0 auto; padding: 3.5rem 1.25rem 5rem; }
  .portal-hero { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(320px, .75fr); gap: 3rem; align-items: start; }
  .portal-eyebrow,.access-kicker { display: block; color: #7a263a; font-size: .75rem; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  .portal-intro h1 { margin: .55rem 0 1rem; font-size: clamp(2.4rem, 5vw, 4.6rem); line-height: .98; color: #24362f; }
  .portal-lead { max-width: 720px; margin: 0 0 2.2rem; font-size: 1.08rem; line-height: 1.75; color: #4a5751; }
  .portal-feature-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 1rem; }
  .portal-feature-grid article { border-top: 1px solid #c9b77f; padding: 1rem 0 .3rem; }
  .portal-feature-grid article span { display: block; margin-bottom: .45rem; color: #a18331; font-size: .72rem; font-weight: 800; }
  .portal-feature-grid strong { display: block; color: #24362f; font-size: 1.02rem; }
  .portal-feature-grid p { margin: .35rem 0 0; color: #69746f; font-size: .9rem; line-height: 1.5; }
  .portal-access-card { position: sticky; top: 2rem; padding: 2rem; background: #f8f5ec; border: 1px solid #dfd6bd; box-shadow: 0 18px 50px rgba(44,55,49,.1); }
  .portal-access-card h2 { margin: .5rem 0 .8rem; color: #24362f; font-size: 1.65rem; }
  .portal-access-card p { color: #5b6661; line-height: 1.55; }
  .portal-access-card label { display: block; margin: 0 0 .45rem; color: #24362f; font-weight: 700; }
  .portal-access-card input[type=email] { width: 100%; box-sizing: border-box; padding: .9rem 1rem; border: 1px solid #bfc6c2; border-radius: 3px; font: inherit; background: #fff; }
  .btn-google,.btn-email,.btn-primary,.btn-secondary { width: 100%; border: 0; padding: .95rem 1rem; font: inherit; font-weight: 800; cursor: pointer; }
  .btn-google { display: flex; justify-content: center; gap: .7rem; margin-top: 1.4rem; color: #24362f; background: #fff; border: 1px solid #bfc6c2; }
  .btn-google span { color: #7a263a; }
  .btn-email,.btn-primary { margin-top: .8rem; color: #fff; background: #7a263a; }
  button:disabled { opacity: .65; cursor: wait; }
  .portal-access-card small { display: block; margin-top: .7rem; color: #727d78; line-height: 1.45; }
  .auth-separator { display: flex; align-items: center; gap: .75rem; margin: 1.1rem 0; color: #8b938f; font-size: .8rem; }
  .auth-separator::before,.auth-separator::after { content:""; flex:1; height:1px; background:#d7d8d2; }
  .portal-access-card footer { margin-top: 1.4rem; padding-top: 1.1rem; border-top: 1px solid #ded8c9; font-size: .86rem; }
  .portal-access-card a { color: #7a263a; font-weight: 700; }
  .portal-message { margin: 1rem 0 0; padding: .8rem 1rem; background: #fff2ef; color: #7a263a; border-left: 3px solid currentColor; }
  .portal-message[data-type=correcto] { background:#eef6ef; color:#356345; }
  .portal-message[data-type=aviso] { background:#fff8e6; color:#7a6022; }
  .loading-line { height: 3px; margin-top: 1.5rem; overflow: hidden; background: #ded8c9; }
  .loading-line::after { content:""; display:block; width:45%; height:100%; background:#7a263a; animation: load 1.2s infinite ease-in-out; }
  @keyframes load { from { transform:translateX(-110%); } to { transform:translateX(260%); } }
  .private-dashboard { margin-top: 2rem; }
  .private-layout,
  .dashboard-main { display: contents; }
  .portal-sidebar-container[hidden] { display: none; }
  .portal-sidebar-container {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 50;
    width: 282px;
    height: 100vh;
  }
  :global(.portal-sidebar-container .private-sidebar) {
    position: static !important;
    width: 282px !important;
    height: 100vh !important;
  }
  .dashboard-header { display:flex; justify-content:space-between; gap:2rem; align-items:end; padding-bottom:1.4rem; border-bottom:1px solid #d8d1bc; }
  .dashboard-header h2 { margin:.45rem 0 .45rem; color:#24362f; font-size:clamp(2rem,4vw,3.2rem); }
  .dashboard-header p { margin:0; color:#63706a; }
  .session-card { min-width:260px; padding:1rem 1.2rem; background:#f8f5ec; }
  .session-card span { display:block; color:#7a263a; font-size:.72rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; }
  .session-card strong { display:block; margin:.35rem 0 .7rem; color:#24362f; font-size:.9rem; word-break:break-word; }
  .session-card button { border:0; padding:0; color:#7a263a; background:none; font:inherit; font-weight:800; cursor:pointer; }
  .dashboard-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:1rem; margin-top:1.5rem; }
  .module-card { position:relative; display:grid; grid-template-columns:auto 1fr auto; gap:1rem; align-items:start; min-height:135px; padding:1.35rem; border:1px solid #d8d1bc; background:#fff; color:inherit; text-decoration:none; transition:.2s ease; }
