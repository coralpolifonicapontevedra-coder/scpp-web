---
import BaseLayout from '../../layouts/Layout.astro';
---

<BaseLayout title="Revisión de fotografías" lang="gl">
  <div class="portal-workspace">
    <aside class="portal-sidebar" aria-label="Navegación do portal privado">
      <div class="portal-brand">
        <p class="portal-brand-name">Sociedade Coral Polifónica de Pontevedra</p>
        <p class="portal-brand-subtitle">Portal do Coralista · Desde 1925</p>
      </div>

      <nav class="portal-nav">
        <a href="/portal/">
          <span aria-hidden="true">⌂</span>
          Inicio
        </a>
        <a href="/portal/fotos/">
          <span aria-hidden="true">＋</span>
          Subir fotografías
        </a>
        <a class="active" href="/portal/revision-fotos/" aria-current="page">
          <span aria-hidden="true">✓</span>
          Revisar fotografías
        </a>
        <span class="portal-nav-disabled">
          <span aria-hidden="true">♫</span>
          Repertorio
          <small>Próximamente</small>
        </span>
        <span class="portal-nav-disabled">
          <span aria-hidden="true">▣</span>
          Concertos
          <small>Próximamente</small>
        </span>
        <span class="portal-nav-disabled">
          <span aria-hidden="true">□</span>
          Documentación
          <small>Próximamente</small>
        </span>
      </nav>

      <div class="portal-sidebar-footer">
        <button id="review-logout" type="button">
          <span aria-hidden="true">↪</span>
          Pechar sesión
        </button>
      </div>
    </aside>

    <main class="review-page">
      <header class="review-page-header">
        <div>
          <p class="eyebrow">Espazo de administración</p>
          <h1>Revisión de fotografías</h1>
          <p class="intro">
            Revisa cada achega antes de incorporala ao arquivo ou publicala na
            galería da Coral.
          </p>
        </div>
        <button id="review-refresh" class="refresh-button" type="button">
          Actualizar
        </button>
      </header>

      <section id="review-shell" class="review-shell" hidden>
        <div class="review-summary">
          <span id="review-count">0</span>
          <span id="review-count-label">fotografías pendentes</span>
        </div>
        <p id="review-message" class="review-message" role="status"
          aria-live="polite"></p>
        <div id="review-list" class="review-list"></div>
        <p id="review-empty" class="review-empty" hidden>
          Non hai fotografías pendentes de revisión.
        </p>
      </section>

      <section id="access-state" class="access-state" aria-live="polite">
        <p>Comprobando a sesión e os permisos de administración…</p>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import { getAuth, onAuthStateChanged, signOut } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQDOIkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.useDeviceLanguage();

  const shell = document.querySelector('#review-shell');
  const estadoAcceso = document.querySelector('#access-state');
  const lista = document.querySelector('#review-list');
  const contador = document.querySelector('#review-count');
  const etiquetaContador = document.querySelector('#review-count-label');
  const baleiro = document.querySelector('#review-empty');
  const mensaxe = document.querySelector('#review-message');
  const actualizar = document.querySelector('#review-refresh');
  const pecharSesion = document.querySelector('#review-logout');

  function escaparHtml(texto) {
    return String(texto ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function urlSegura(valor) {
    const url = String(valor ?? '').trim();
    return /^https:\/\//i.test(url) ? url : '';
  }

  function mostrarMensaxe(texto = '', tipo = '') {
    if (!(mensaxe instanceof HTMLElement)) return;
    mensaxe.textContent = texto;
    mensaxe.dataset.tipo = tipo;
    mensaxe.hidden = !texto;
  }

  function mostrarAcceso(texto, conLigazon = false) {
    if (!(estadoAcceso instanceof HTMLElement)) return;
    estadoAcceso.innerHTML = conLigazon
      ? `<p>${escaparHtml(texto)}</p><a href="/portal/">Ir ao portal privado</a>`
      : `<p>${escaparHtml(texto)}</p>`;
    estadoAcceso.hidden = false;
  }

  async function solicitar(accion, datos = {}) {
    const usuario = auth.currentUser;
    if (!usuario?.email) throw new Error('A sesión non está activa.');
    const idToken = await usuario.getIdToken(true);
    const resposta = await fetch('/api/fotos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion, ...datos })
    });
    const resultado = await resposta.json().catch(() => null);
    if (!resposta.ok || !resultado?.ok) {
      throw new Error(resultado?.erro || 'Non foi posible completar a revisión.');
    }
    return resultado;
  }

  function debuxarFotos(fotos) {
    if (!(lista instanceof HTMLElement) ||
        !(contador instanceof HTMLElement) ||
        !(etiquetaContador instanceof HTMLElement) ||
        !(baleiro instanceof HTMLElement)) return;

    contador.textContent = String(fotos.length);
    etiquetaContador.textContent = fotos.length === 1
      ? 'fotografía pendente' : 'fotografías pendentes';
    baleiro.hidden = fotos.length !== 0;

    lista.innerHTML = fotos.map((foto, indice) => {
      const miniaturaUrl = urlSegura(foto.miniaturaUrl);
      const ficheiroUrl = urlSegura(foto.ficheiroUrl);
      const evento = foto.evento || foto.concerto || '';

      return `
        <article class="photo-review-card" data-row-id="${escaparHtml(foto.rowId)}">
          <div class="photo-media">
            ${miniaturaUrl
              ? `<a class="photo-preview-link" href="${escaparHtml(ficheiroUrl || miniaturaUrl)}" target="_blank" rel="noopener noreferrer" aria-label="Abrir a fotografía orixinal">
                  <img src="${escaparHtml(miniaturaUrl)}" alt="${escaparHtml(foto.titulo || `Fotografía ${indice + 1}`)}" loading="lazy" />
                </a>`
              : '<div class="photo-placeholder">Sen miniatura dispoñible</div>'}
          </div>

          <div class="photo-content">
            <header class="photo-heading">
              <div>
                <p class="photo-number">Fotografía ${indice + 1}</p>
                <h2>${escaparHtml(foto.titulo || 'Fotografía sen título')}</h2>
              </div>
              <div class="photo-meta">
                <span>${escaparHtml(foto.data || foto.anoAproximado || 'Sen data')}</span>
                <span>${escaparHtml(foto.lugar || 'Lugar sen indicar')}</span>
              </div>
            </header>

            <div class="form-grid">
              <label class="form-field form-field-wide">
                <span>Título</span>
                <input name="titulo" value="${escaparHtml(foto.titulo)}" maxlength="120" />
              </label>

              <label class="form-field form-field-wide">
                <span>Pé de foto</span>
                <textarea name="peFoto" rows="4" maxlength="600">${escaparHtml(foto.peFoto)}</textarea>
              </label>

              <div class="info-field">
                <span>Evento ou concerto</span>
                <p>${escaparHtml(evento || 'Sen indicar')}</p>
              </div>

              <div class="info-field">
                <span>Autoría</span>
                <p>${escaparHtml(foto.autor || 'Sen indicar')}</p>
              </div>

              <label class="form-field form-field-wide">
                <span>Observacións internas</span>
                <textarea name="observacions" rows="3" maxlength="500">${escaparHtml(foto.observacions)}</textarea>
              </label>
            </div>

            <label class="featured-option">
              <input type="checkbox" name="destacada" />
              <span>Destacar na galería se se publica</span>
            </label>

            <div class="decision-actions">
              <button class="primary-action" type="button" data-review-action="publicar">
                <strong>Aceptar e publicar</strong>
                <small>Incorporar á galería pública</small>
              </button>
              <button type="button" data-review-action="aceptar">
                <strong>Aceptar sen publicar</strong>
                <small>Conservar só no arquivo</small>
              </button>
              <button class="reject-action" type="button" data-review-action="rexeitar">
                <strong>Rexeitar</strong>
                <small>Eliminar o rexistro</small>
              </button>
            </div>

            ${ficheiroUrl ? `
              <a class="drive-link" href="${escaparHtml(ficheiroUrl)}"
                target="_blank" rel="noopener noreferrer">Abrir o orixinal en Drive ↗</a>` : ''}
          </div>
        </article>`;
    }).join('');
  }

  async function cargarFotos() {
    if (actualizar instanceof HTMLButtonElement) {
      actualizar.disabled = true;
      actualizar.textContent = 'Actualizando…';
    }
    mostrarMensaxe('Cargando fotografías pendentes…', 'cargando');
    try {
      const resultado = await solicitar('listarFotosRevision');
      if (estadoAcceso instanceof HTMLElement) estadoAcceso.hidden = true;
      if (shell instanceof HTMLElement) shell.hidden = false;
      debuxarFotos(Array.isArray(resultado.fotos) ? resultado.fotos : []);
      mostrarMensaxe();
    } catch (erro) {
      if (shell instanceof HTMLElement) shell.hidden = true;
      mostrarAcceso(
        erro instanceof Error ? erro.message : 'Administración non autorizada.',
        true
      );
    } finally {
      if (actualizar instanceof HTMLButtonElement) {
        actualizar.disabled = false;
        actualizar.textContent = 'Actualizar';
      }
    }
  }

  onAuthStateChanged(auth, (usuario) => {
    if (!usuario?.email) {
      if (shell instanceof HTMLElement) shell.hidden = true;
      mostrarAcceso(
        'Identifícate primeiro no portal privado para revisar fotografías.',
        true
      );
      return;
    }
    cargarFotos();
  });

  actualizar?.addEventListener('click', cargarFotos);

  pecharSesion?.addEventListener('click', async () => {
    if (pecharSesion instanceof HTMLButtonElement) {
      pecharSesion.disabled = true;
      pecharSesion.textContent = 'Pechando sesión…';
    }
    await signOut(auth);
    window.location.href = '/portal/';
  });

  lista?.addEventListener('click', async (evento) => {
    const pulsado = evento.target;
    if (!(pulsado instanceof Element)) return;
    const boton = pulsado.closest('button[data-review-action]');
    if (!(boton instanceof HTMLButtonElement)) return;
    const accion = boton.dataset.reviewAction;
    const tarxeta = boton.closest('.photo-review-card');
    if (!accion || !(tarxeta instanceof HTMLElement)) return;

    if (accion === 'rexeitar' && !window.confirm(
      'Queres rexeitar esta fotografía e eliminar o seu rexistro? O ficheiro orixinal conservarase en Drive.'
    )) return;

    const titulo = tarxeta.querySelector('[name="titulo"]');
    const peFoto = tarxeta.querySelector('[name="peFoto"]');
    const observacions = tarxeta.querySelector('[name="observacions"]');
    const destacada = tarxeta.querySelector('[name="destacada"]');
    const botons = tarxeta.querySelectorAll('button[data-review-action]');
    botons.forEach((elemento) => {
      if (elemento instanceof HTMLButtonElement) elemento.disabled = true;
    });

    try {
      const resultado = await solicitar('actualizarRevisionFoto', {
        rowId: tarxeta.dataset.rowId,
        estado: accion === 'rexeitar' ? 'Rexeitada' : 'Aprobada',
        publicar: accion === 'publicar',
        eliminar: accion === 'rexeitar',
        titulo: titulo instanceof HTMLInputElement ? titulo.value : '',
        peFoto: peFoto instanceof HTMLTextAreaElement ? peFoto.value : '',
        observacions: observacions instanceof HTMLTextAreaElement
          ? observacions.value : '',
        destacada: destacada instanceof HTMLInputElement && destacada.checked
      });
      await cargarFotos();
      mostrarMensaxe(resultado.mensaxe, 'correcto');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (erro) {
      mostrarMensaxe(
        erro instanceof Error ? erro.message : 'Non foi posible revisar a fotografía.',
        'erro'
      );
      botons.forEach((elemento) => {
        if (elemento instanceof HTMLButtonElement) elemento.disabled = false;
      });
    }
  });
</script>

<style>
  .portal-workspace {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    min-height: calc(100vh - 1px);
    font-family: var(--fuente-minimalista);
  }

  .portal-workspace :where(button, input, textarea) {
    font-family: var(--fuente-minimalista);
  }

  .portal-sidebar {
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    height: 100vh;
    padding: 2rem 1.35rem 1.3rem;
    border-right: 1px solid #ddd5cc;
    background: #f7f3eb;
  }

  .portal-brand {
    padding: 0 0.65rem 1.6rem;
    border-bottom: 1px solid #ddd5cc;
  }

  .portal-brand-name {
    margin: 0;
    color: var(--color-principal);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .portal-brand-subtitle {
    margin: 0.4rem 0 0;
    color: #716a64;
    font-size: 0.68rem;
    letter-spacing: 0.035em;
  }

  .portal-nav {
    display: grid;
    gap: 0.35rem;
    margin-top: 1.45rem;
  }

  .portal-nav a,
  .portal-nav-disabled,
  .portal-sidebar-footer button {
    display: grid;
    grid-template-columns: 1.25rem minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.65rem;
    min-height: 2.75rem;
    padding: 0.65rem 0.75rem;
    border: 0;
    border-radius: 4px;
    background: transparent;
    color: #4e4945;
    font-size: 0.8rem;
    font-weight: 650;
    text-align: left;
  }

  .portal-nav a:hover,
  .portal-nav a.active {
    background: var(--color-blanco);
    color: var(--color-principal);
    box-shadow: 0 4px 16px rgba(60, 40, 28, 0.06);
  }

  .portal-nav a.active {
    border-left: 3px solid var(--color-acento);
  }

  .portal-nav-disabled {
    color: #99918a;
    cursor: default;
  }

  .portal-nav-disabled small {
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .portal-sidebar-footer {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid #ddd5cc;
  }

  .portal-sidebar-footer button {
    width: 100%;
    cursor: pointer;
  }

  .portal-sidebar-footer button:hover {
    background: rgba(106, 27, 41, 0.06);
    color: var(--color-principal);
  }

  .review-page {
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4.5rem) clamp(1.5rem, 5vw, 4.5rem) 6rem;
  }

  .review-page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.4rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #ddd5cc;
  }

  .eyebrow,
  .photo-number {
    margin: 0;
    color: var(--color-acento);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .review-page-header h1 {
    margin: 0.25rem 0 0;
    font-size: clamp(1.85rem, 4vw, 2.65rem);
    letter-spacing: -0.025em;
  }

  .intro {
    max-width: 680px;
    margin: 0.55rem 0 0;
    color: #625c57;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .refresh-button {
    flex: 0 0 auto;
    min-height: 2.75rem;
    padding: 0.65rem 1.15rem;
    border: 1px solid var(--color-principal);
    background: transparent;
    color: var(--color-principal);
    font-size: 0.78rem;
    font-weight: 700;
    cursor: pointer;
  }

  .refresh-button:hover:not(:disabled) {
    background: var(--color-principal);
    color: var(--color-blanco);
  }

  .refresh-button:disabled { cursor: wait; opacity: 0.55; }

  .review-shell[hidden],
  .access-state[hidden],
  .review-message[hidden] { display: none; }

  .review-summary {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    margin-bottom: 1.25rem;
    color: #68625d;
    font-size: 0.86rem;
  }

  .review-summary span:first-child {
    color: var(--color-principal);
    font-size: 1.45rem;
    font-weight: 700;
  }

  .review-message,
  .access-state,
  .review-empty {
    margin: 0 0 1.4rem;
    padding: 1rem 1.2rem;
    border: 1px solid #ded8d0;
    background: #fdfbf7;
    color: #5f5b57;
    font-size: 0.88rem;
  }

  .review-message[data-tipo='correcto'] {
    border-left: 3px solid var(--color-acento);
    color: var(--color-principal);
  }

  .review-message[data-tipo='erro'] { border-left: 3px solid var(--color-principal); }
  .access-state { max-width: 620px; margin: 5rem auto; text-align: center; }
  .access-state p { margin: 0; }
  .access-state a {
    display: inline-block;
    margin-top: 0.8rem;
    color: var(--color-principal);
    font-weight: 700;
  }

  .review-list { display: grid; gap: 2.2rem; }

  .photo-review-card {
    overflow: hidden;
    border: 1px solid #d9d1c8;
    border-radius: 6px;
    background: var(--color-blanco);
    box-shadow: 0 14px 38px rgba(64, 43, 30, 0.07);
  }

  .photo-media {
    display: grid;
    min-height: 440px;
    max-height: 620px;
    padding: 1.5rem;
    place-items: center;
    border-bottom: 1px solid #ddd5cc;
    background: #f2eee5;
  }

  .photo-preview-link {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    cursor: zoom-in;
  }

  .photo-media img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 570px;
    object-fit: contain;
  }

  .photo-placeholder {
    display: grid;
    min-height: 360px;
    place-items: center;
    color: #77716b;
    font-size: 0.85rem;
  }

  .photo-content {
    display: grid;
    gap: 1.4rem;
    padding: clamp(1.5rem, 3vw, 2.25rem);
  }

  .photo-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding-bottom: 1.15rem;
    border-bottom: 1px solid #e3ddd6;
  }

  .photo-heading h2 {
    margin: 0.25rem 0 0;
    font-size: 1.22rem;
  }

  .photo-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.45rem 1.2rem;
    color: #6b655f;
    font-size: 0.78rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .form-field,
  .info-field {
    display: grid;
    align-content: start;
    gap: 0.4rem;
    min-width: 0;
  }

  .form-field-wide { grid-column: 1 / -1; }

  .form-field > span,
  .info-field > span {
    color: var(--color-principal);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.025em;
  }

  .form-field input,
  .form-field textarea,
  .info-field p {
    width: 100%;
    min-height: 3rem;
    margin: 0;
    padding: 0.75rem 0.85rem;
    border: 1px solid #cbc3ba;
    border-radius: 3px;
    background: #fff;
    color: var(--color-texto);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .form-field textarea {
    resize: vertical;
  }

  .info-field p {
    background: #faf8f4;
    color: #625c57;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--color-principal);
    outline: 2px solid rgba(106, 27, 41, 0.1);
    outline-offset: 1px;
  }

  .featured-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    min-height: 3rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid #ddd5cc;
    border-radius: 3px;
    background: #faf8f4;
    color: #514c48;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
  }

  .featured-option input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--color-principal);
  }

  .decision-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .decision-actions button {
    display: grid;
    align-content: center;
    gap: 0.2rem;
    min-height: 4.6rem;
    padding: 0.8rem;
    border: 1px solid #bcb3aa;
    border-radius: 3px;
    background: transparent;
    color: var(--color-principal);
    cursor: pointer;
  }

  .decision-actions button strong {
    font-size: 0.76rem;
  }

  .decision-actions button small {
    color: #77706a;
    font-size: 0.65rem;
    font-weight: 500;
  }

  .decision-actions button:hover:not(:disabled) {
    border-color: var(--color-principal);
    background: rgba(106, 27, 41, 0.04);
  }

  .decision-actions .primary-action {
    border-color: var(--color-principal);
    background: var(--color-principal);
    color: var(--color-blanco);
  }

  .decision-actions .primary-action small { color: rgba(255, 255, 255, 0.76); }
  .decision-actions .primary-action:hover:not(:disabled) { background: #53131f; }
  .decision-actions .reject-action { color: #6c5555; }
  .decision-actions button:disabled { cursor: wait; opacity: 0.5; }

  .drive-link {
    width: fit-content;
    color: var(--color-principal);
    font-size: 0.78rem;
    font-weight: 700;
    border-bottom: 1px solid var(--color-acento);
  }

  .review-empty { text-align: center; }

  @media (max-width: 900px) {
    .portal-workspace { grid-template-columns: 1fr; }
    .portal-sidebar {
