---
import BaseLayout from '../../layouts/Layout.astro';
import PortalSidebar from '../../components/PortalSidebar.astro';
---

<BaseLayout title="Revisión de fotografías" lang="gl">
  <div class="private-layout">
    <PortalSidebar active="revisar" logoutId="review-logout" />

    <main class="review-main">
      <header class="private-page-header">
        <div>
          <h1>Revisar fotografías</h1>
          <p>Revisa, completa os datos e decide se a fotografía será publicada na galería.</p>
        </div>

        <div class="pending-card" aria-label="Fotografías pendentes de revisión">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="13" height="13" rx="1.5" /><path d="m7 14 3-3 2.2 2.2 2-2L17 14M16 8h4v12H8v-3" /></svg>
          <span>
            <small>Pendentes de revisar</small>
            <strong id="review-count">0</strong>
          </span>
          <button id="review-refresh" type="button" title="Actualizar fotografías" aria-label="Actualizar fotografías">↻</button>
        </div>
      </header>

      <section id="review-shell" class="review-shell" hidden>
        <div class="review-navigation">
          <button id="review-previous" type="button">← <span>Anterior</span></button>
          <strong id="review-position">0 de 0</strong>
          <button id="review-next" type="button"><span>Seguinte</span> →</button>
        </div>

        <p id="review-message" class="portal-message" role="status" aria-live="polite" hidden></p>
        <div id="review-list"></div>
        <p id="review-empty" class="review-empty" hidden>Non hai fotografías pendentes de revisión.</p>
      </section>

      <section id="access-state" class="access-state" aria-live="polite">
        <p>Comprobando a sesión e os permisos de administración…</p>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import { getAuth, onAuthStateChanged, signOut } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQDOIkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const app = getApps().length ? getApp() : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  auth.useDeviceLanguage();

  const shell = document.querySelector('#review-shell');
  const estadoAcceso = document.querySelector('#access-state');
  const lista = document.querySelector('#review-list');
  const contador = document.querySelector('#review-count');
  const posicion = document.querySelector('#review-position');
  const baleiro = document.querySelector('#review-empty');
  const mensaxe = document.querySelector('#review-message');
  const actualizar = document.querySelector('#review-refresh');
  const anterior = document.querySelector('#review-previous');
  const seguinte = document.querySelector('#review-next');
  const pecharSesion = document.querySelector('#review-logout');

  let fotosRevision = [];
  let indiceActual = 0;

  function escaparHtml(texto) {
    return String(texto ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function urlSegura(valor) {
    const url = String(valor ?? '').trim();
    return /^https:\/\//i.test(url) ? url : '';
  }

  function primeiroValor(...valores) {
    return valores.find((valor) => String(valor ?? '').trim()) ?? '';
  }

  function mostrarMensaxe(texto = '', tipo = '') {
    if (!(mensaxe instanceof HTMLElement)) return;
    mensaxe.textContent = texto;
    mensaxe.dataset.tipo = tipo;
    mensaxe.hidden = !texto;
  }

  function mostrarAcceso(texto, conLigazon = false) {
    if (!(estadoAcceso instanceof HTMLElement)) return;
    estadoAcceso.innerHTML = conLigazon
      ? `<p>${escaparHtml(texto)}</p><a href="/portal/">Ir ao portal privado</a>`
      : `<p>${escaparHtml(texto)}</p>`;
    estadoAcceso.hidden = false;
  }

  async function solicitar(accion, datos = {}) {
    const usuario = auth.currentUser;
    if (!usuario?.email) throw new Error('A sesión non está activa.');
    const idToken = await usuario.getIdToken(true);
    const resposta = await fetch('/api/fotos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion, ...datos })
    });
    const resultado = await resposta.json().catch(() => null);
    if (!resposta.ok || !resultado?.ok) {
      throw new Error(resultado?.erro || 'Non foi posible completar a revisión.');
    }
    return resultado;
  }

  function actualizarNavegacion() {
    const total = fotosRevision.length;
    if (contador instanceof HTMLElement) contador.textContent = String(total);
    if (posicion instanceof HTMLElement) posicion.textContent = total ? `${indiceActual + 1} de ${total}` : '0 de 0';
    if (anterior instanceof HTMLButtonElement) anterior.disabled = indiceActual <= 0 || total === 0;
    if (seguinte instanceof HTMLButtonElement) seguinte.disabled = indiceActual >= total - 1 || total === 0;
    if (baleiro instanceof HTMLElement) baleiro.hidden = total !== 0;
  }

  function debuxarFotoActual() {
    if (!(lista instanceof HTMLElement)) return;
    actualizarNavegacion();

    const foto = fotosRevision[indiceActual];
    if (!foto) {
      lista.innerHTML = '';
      return;
    }

    const miniaturaUrl = urlSegura(foto.miniaturaUrl);
    const ficheiroUrl = urlSegura(foto.ficheiroUrl);
    const evento = primeiroValor(foto.evento, foto.concerto, 'Sen indicar');
    const data = primeiroValor(foto.data, foto.dataFoto, foto.anoAproximado, 'Sen indicar');
    const lugar = primeiroValor(foto.lugar, 'Sen indicar');
    const autor = primeiroValor(foto.autor, foto.autoria, foto.procedencia, 'Sen indicar');
    const persoa = primeiroValor(foto.persoa, foto.nome, foto.email, foto.usuario, foto.subidaPor, 'Sen indicar');

    lista.innerHTML = `
      <article class="review-card-v2" data-row-id="${escaparHtml(foto.rowId)}">
        <div class="review-photo-column">
          <div class="review-photo-frame">
            ${miniaturaUrl
              ? `<a href="${escaparHtml(ficheiroUrl || miniaturaUrl)}" target="_blank" rel="noopener noreferrer" aria-label="Abrir a fotografía orixinal">
                   <img src="${escaparHtml(miniaturaUrl)}" alt="${escaparHtml(foto.titulo || 'Fotografía pendente de revisión')}" />
                 </a>`
              : '<div class="review-photo-placeholder">Sen miniatura dispoñible</div>'}
          </div>

          ${ficheiroUrl
            ? `<a class="original-photo-button" href="${escaparHtml(ficheiroUrl)}" target="_blank" rel="noopener noreferrer">
                 <span aria-hidden="true">↗</span> Ver foto orixinal en Drive
               </a>`
            : ''}
        </div>

        <div class="review-form-column">
          <label class="review-field">
            <span>Evento / Concerto</span>
            <input readonly value="${escaparHtml(evento)}" />
          </label>

          <label class="review-field">
            <span>Data</span>
            <input readonly value="${escaparHtml(data)}" />
          </label>

          <label class="review-field">
            <span>Lugar</span>
            <input readonly value="${escaparHtml(lugar)}" />
          </label>

          <label class="review-field">
            <span>Título ou descrición</span>
            <input name="titulo" maxlength="120" value="${escaparHtml(foto.titulo)}" />
          </label>

          <label class="review-field">
            <span>Autor / Procedencia</span>
            <input readonly value="${escaparHtml(autor)}" />
          </label>

          <label class="review-field">
            <span>Persoa que subiu a foto</span>
            <input readonly value="${escaparHtml(persoa)}" />
          </label>

          <label class="review-field">
            <span>Pé de foto</span>
            <textarea name="peFoto" rows="3" maxlength="600">${escaparHtml(foto.peFoto)}</textarea>
          </label>

          <label class="review-field">
            <span>Notas privadas</span>
            <textarea name="observacions" rows="3" maxlength="500">${escaparHtml(foto.observacions)}</textarea>
          </label>

          <label class="featured-option-v2">
            <input type="checkbox" name="destacada" />
            <span>Destacar na galería se se publica</span>
          </label>

          <div class="review-actions-v2">
            <button class="reject-button" type="button" data-review-action="rexeitar">Rexeitar</button>
            <button class="accept-button" type="button" data-review-action="aceptar">Aceptar</button>
            <button class="publish-button" type="button" data-review-action="publicar">Publicar na galería</button>
          </div>
        </div>
      </article>`;
  }

  async function cargarFotos() {
    if (actualizar instanceof HTMLButtonElement) {
      actualizar.disabled = true;
      actualizar.textContent = '…';
    }
    mostrarMensaxe('Cargando fotografías pendentes…', 'cargando');

    try {
      const resultado = await solicitar('listarFotosRevision');
      fotosRevision = Array.isArray(resultado.fotos) ? resultado.fotos : [];
      indiceActual = Math.min(indiceActual, Math.max(0, fotosRevision.length - 1));
      if (estadoAcceso instanceof HTMLElement) estadoAcceso.hidden = true;
      if (shell instanceof HTMLElement) shell.hidden = false;
      debuxarFotoActual();
      mostrarMensaxe();
    } catch (erro) {
      if (shell instanceof HTMLElement) shell.hidden = true;
      mostrarAcceso(
        erro instanceof Error ? erro.message : 'Administración non autorizada.',
        true
      );
    } finally {
      if (actualizar instanceof HTMLButtonElement) {
        actualizar.disabled = false;
        actualizar.textContent = '↻';
      }
    }
  }

  onAuthStateChanged(auth, (usuario) => {
    if (!usuario?.email) {
      if (shell instanceof HTMLElement) shell.hidden = true;
      mostrarAcceso('Identifícate primeiro no portal privado para revisar fotografías.', true);
      return;
    }
    cargarFotos();
  });

  actualizar?.addEventListener('click', cargarFotos);

  anterior?.addEventListener('click', () => {
    if (indiceActual <= 0) return;
    indiceActual -= 1;
    debuxarFotoActual();
  });

  seguinte?.addEventListener('click', () => {
    if (indiceActual >= fotosRevision.length - 1) return;
    indiceActual += 1;
    debuxarFotoActual();
  });

  pecharSesion?.addEventListener('click', async () => {
    if (pecharSesion instanceof HTMLButtonElement) pecharSesion.disabled = true;
    await signOut(auth);
    window.location.href = '/portal/';
  });

  lista?.addEventListener('click', async (eventoClick) => {
    const pulsado = eventoClick.target;
    if (!(pulsado instanceof Element)) return;
    const boton = pulsado.closest('button[data-review-action]');
    if (!(boton instanceof HTMLButtonElement)) return;

    const accion = boton.dataset.reviewAction;
    const tarxeta = boton.closest('.review-card-v2');
    if (!accion || !(tarxeta instanceof HTMLElement)) return;

    if (accion === 'rexeitar' && !window.confirm(
      'Queres rexeitar esta fotografía e eliminar o seu rexistro? O ficheiro orixinal conservarase en Drive.'
    )) return;

    const titulo = tarxeta.querySelector('[name="titulo"]');
    const peFoto = tarxeta.querySelector('[name="peFoto"]');
    const observacions = tarxeta.querySelector('[name="observacions"]');
    const destacada = tarxeta.querySelector('[name="destacada"]');
    const botons = tarxeta.querySelectorAll('button[data-review-action]');

    botons.forEach((elemento) => {
      if (elemento instanceof HTMLButtonElement) elemento.disabled = true;
    });

    try {
      const resultado = await solicitar('actualizarRevisionFoto', {
        rowId: tarxeta.dataset.rowId,
        estado: accion === 'rexeitar' ? 'Rexeitada' : 'Aprobada',
        publicar: accion === 'publicar',
        eliminar: accion === 'rexeitar',
        titulo: titulo instanceof HTMLInputElement ? titulo.value : '',
        peFoto: peFoto instanceof HTMLTextAreaElement ? peFoto.value : '',
        observacions: observacions instanceof HTMLTextAreaElement ? observacions.value : '',
        destacada: destacada instanceof HTMLInputElement && destacada.checked
      });

      await cargarFotos();
      mostrarMensaxe(resultado.mensaxe || 'Revisión gardada correctamente.', 'correcto');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (erro) {
      mostrarMensaxe(
        erro instanceof Error ? erro.message : 'Non foi posible revisar a fotografía.',
        'erro'
      );
      botons.forEach((elemento) => {
        if (elemento instanceof HTMLButtonElement) elemento.disabled = false;
      });
    }
  });
</script>

<style>
  .private-layout {
    display: grid;
    grid-template-columns: 282px minmax(0, 1fr);
    min-height: 100vh;
    background: #fff;
  }

  .review-main {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.7rem clamp(1.5rem, 4vw, 4.2rem) 4rem;
  }

  .private-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .private-page-header h1 {
    margin: 0 0 .45rem;
    color: var(--color-principal);
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    letter-spacing: -.025em;
  }

  .private-page-header p {
    max-width: 760px;
    margin: 0;
    color: #5f5b58;
    font-size: .94rem;
  }

  .pending-card {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr) 30px;
    align-items: center;
    gap: .75rem;
    min-width: 245px;
    padding: .85rem .9rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #fff;
  }

  .pending-card > svg {
    width: 38px;
    height: 38px;
    fill: none;
    stroke: var(--color-principal);
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .pending-card > span {
    display: grid;
    gap: .1rem;
  }

  .pending-card small {
    color: #5d5956;
    font-size: .72rem;
  }

  .pending-card strong {
    color: var(--color-principal);
    font-size: 1.3rem;
    line-height: 1;
  }

  .pending-card button {
    display: grid;
    width: 29px;
    height: 29px;
    place-items: center;
    border: 0;
    border-radius: 50%;
    background: #f5f1f1;
    color: var(--color-principal);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .review-shell[hidden],
  .access-state[hidden],
  .portal-message[hidden],
  .review-empty[hidden] {
    display: none;
  }

  .review-navigation {
    display: grid;
    grid-template-columns: 150px 1fr 150px;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.15rem;
    padding-top: 1.1rem;
    border-top: 1px solid #e5e1dd;
  }

  .review-navigation strong {
    color: #3d3936;
    font-size: .88rem;
    text-align: center;
  }

  .review-navigation button {
    min-height: 2.75rem;
    padding: .65rem 1rem;
    border: 1px solid var(--color-principal);
    border-radius: 3px;
    background: #fff;
    color: var(--color-principal);
    font: inherit;
    font-size: .85rem;
    font-weight: 700;
    cursor: pointer;
  }

  .review-navigation button:last-child {
    justify-self: end;
  }

  .review-navigation button:disabled {
    border-color: #d4d0cc;
    color: #aaa39e;
    cursor: default;
  }

  .portal-message,
  .access-state,
  .review-empty {
    margin: 0 0 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #faf9f7;
    color: #5d5956;
    font-size: .86rem;
  }

  .portal-message[data-tipo='correcto'] {
    border-left: 3px solid #3d7950;
    background: #f2f8f3;
    color: #356345;
  }

  .portal-message[data-tipo='erro'] {
    border-left: 3px solid var(--color-principal);
  }

  .access-state {
    max-width: 620px;
    margin: 5rem auto;
    text-align: center;
  }

  .access-state a {
    display: inline-block;
    margin-top: .75rem;
    color: var(--color-principal);
    font-weight: 700;
  }

  .review-empty {
    text-align: center;
  }

  .review-card-v2 {
    display: grid;
    grid-template-columns: minmax(340px, 1.08fr) minmax(360px, .92fr);
    gap: 1.5rem;
    padding: 1.55rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #fff;
  }

  .review-photo-column {
    display: grid;
    align-content: start;
    justify-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .review-photo-frame {
    display: grid;
    width: 100%;
    min-height: 470px;
    place-items: center;
    overflow: hidden;
    border-radius: 4px;
    background: #f4f2ef;
  }

  .review-photo-frame a {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    cursor: zoom-in;
  }

  .review-photo-frame img {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 660px;
    object-fit: contain;
  }

  .review-photo-placeholder {
    color: #77716c;
    font-size: .84rem;
  }

  .original-photo-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    min-height: 2.65rem;
    padding: .6rem 1rem;
    border: 1px solid var(--color-principal);
    border-radius: 3px;
    color: var(--color-principal);
    font-size: .82rem;
    font-weight: 700;
  }

  .original-photo-button:hover {
    background: #f8f1f2;
  }

  .review-form-column {
    display: grid;
    align-content: start;
    gap: .85rem;
    min-width: 0;
  }

  .review-field {
    display: grid;
    gap: .38rem;
  }

  .review-field > span {
    color: #35312f;
    font-size: .77rem;
    font-weight: 700;
  }

  .review-field input,
  .review-field textarea {
    width: 100%;
    min-height: 2.78rem;
    padding: .68rem .78rem;
    border: 1px solid #d4d0cc;
    border-radius: 3px;
    background: #fff;
    color: #393532;
    font: inherit;
    font-size: .86rem;
  }

  .review-field input[readonly] {
    background: #faf9f7;
    color: #625e5a;
  }

  .review-field textarea {
    min-height: 4.6rem;
    resize: vertical;
  }

  .review-field input:focus,
  .review-field textarea:focus {
    border-color: var(--color-principal);
    outline: 2px solid rgba(106, 27, 41, .08);
    outline-offset: 1px;
  }

  .featured-option-v2 {
    display: flex;
    align-items: center;
    gap: .6rem;
    color: #5b5652;
    font-size: .8rem;
  }

  .featured-option-v2 input {
    accent-color: var(--color-principal);
  }

  .review-actions-v2 {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: .65rem;
    margin-top: .4rem;
  }

  .review-actions-v2 button {
    min-height: 2.85rem;
    padding: .65rem .7rem;
    border-radius: 3px;
    background: #fff;
    font: inherit;
    font-size: .8rem;
    font-weight: 750;
    cursor: pointer;
  }

  .reject-button {
    border: 1px solid #c49b62;
    color: #9a641c;
  }

  .accept-button {
    border: 1px solid var(--color-principal);
    color: var(--color-principal);
  }

  .publish-button {
    border: 1px solid var(--color-principal);
    background: var(--color-principal) !important;
    color: #fff;
  }

  .review-actions-v2 button:disabled {
    cursor: wait;
    opacity: .55;
  }

  @media (max-width: 1080px) {
    .review-card-v2 {
      grid-template-columns: 1fr;
    }

    .review-photo-frame {
      min-height: 360px;
    }
  }

  @media (max-width: 900px) {
    .private-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .review-main {
      padding: 1.7rem 1rem 3rem;
    }

    .private-page-header {
      flex-direction: column;
    }

    .pending-card {
      width: 100%;
    }

    .review-navigation {
      grid-template-columns: 1fr auto 1fr;
    }

    .review-navigation button {
      padding: .6rem .7rem;
    }

    .review-navigation button span {
      display: none;
    }

    .review-card-v2 {
      padding: 1rem;
    }

    .review-actions-v2 {
      grid-template-columns: 1fr;
    }
  }
</style>
