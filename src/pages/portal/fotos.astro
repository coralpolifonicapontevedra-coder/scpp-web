---
import BaseLayout from '../../layouts/Layout.astro';
import PortalSidebar from '../../components/PortalSidebar.astro';
---

<BaseLayout title="Subir fotografías" lang="gl">
  <div class="private-layout">
    <PortalSidebar active="subir" logoutId="photo-logout" />

    <main class="upload-main">
      <header class="private-page-header">
        <div>
          <h1>Subir fotografías</h1>
          <p>Sube as túas fotografías. Unha vez enviadas, serán revisadas antes de incorporalas ao arquivo ou publicalas nas galerías da Coral.</p>
        </div>

        <div class="account-card" aria-label="Conta identificada">
          <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="13" height="13" rx="1.5" /><path d="m7 14 3-3 2.2 2.2 2-2L17 14M16 8h4v12H8v-3" /></svg>
          <span>
            <small>Conta identificada</small>
            <strong id="user-email">—</strong>
          </span>
        </div>
      </header>

      <section id="loading" class="portal-state">Comprobando o teu acceso…</section>

      <form id="photo-form" class="upload-card" hidden>
        <section class="upload-section information-section">
          <h2>Información da fotografía</h2>

          <div class="upload-grid">
            <label class="upload-field">
              <span>Evento</span>
              <input name="evento" maxlength="160" placeholder="Nome do evento" />
            </label>

            <label class="upload-field">
              <span>Concerto</span>
              <input name="concerto" maxlength="160" placeholder="Nome do concerto" />
            </label>

            <label class="upload-field">
              <span>Data</span>
              <input name="dataFoto" type="date" />
            </label>

            <label class="upload-field">
              <span>Lugar</span>
              <input name="lugar" maxlength="120" placeholder="Lugar da fotografía" />
            </label>

            <label class="upload-field">
              <span>Ano aproximado</span>
              <input name="anoAproximado" type="number" min="1900" max="2100" placeholder="Ex.: 1956" />
            </label>

            <label class="upload-field">
              <span>Autoría</span>
              <input name="autoria" maxlength="120" placeholder="Autor ou autora" />
            </label>

            <label class="upload-field">
              <span>Título ou descrición *</span>
              <input name="titulo" maxlength="120" required placeholder="Describe brevemente a fotografía" />
            </label>

            <label class="upload-field">
              <span>Procedencia</span>
              <input name="procedencia" maxlength="160" placeholder="Arquivo, persoa ou entidade" />
            </label>

            <label class="upload-field">
              <span>Persoa que subiu a foto</span>
              <input id="uploader-email" readonly value="" />
            </label>

            <label class="upload-field upload-field-wide">
              <span>Pé de foto</span>
              <textarea name="peFoto" rows="3" maxlength="600" placeholder="Texto que podería acompañar a fotografía na galería"></textarea>
            </label>
          </div>

          <label class="rights-check">
            <input name="confirmaDereitos" type="checkbox" required />
            <span>Confirmo que a Coral pode conservar esta imaxe e que dispoño de autorización para achegala para a súa posible publicación.</span>
          </label>
        </section>

        <section class="upload-section file-section">
          <h2>Selecciona a fotografía</h2>

          <div id="file-drop-zone" class="file-drop-zone">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 16V5m0 0L8 9m4-4 4 4M5.5 18.5a4 4 0 0 1 .6-7.95A6 6 0 0 1 17.6 9a4.5 4.5 0 0 1 .9 8.9" /></svg>
            <strong>Arrastra aquí a túa fotografía</strong>
            <span>ou</span>
            <label class="file-picker" for="photo-file">Seleccionar arquivo</label>
            <input id="photo-file" name="foto" type="file" accept="image/jpeg,image/png,image/webp" required />
            <small id="selected-file-name">Formatos permitidos: JPG, PNG, WebP · Tamaño máximo: 8 MB</small>

            <figure id="photo-preview" class="photo-preview" hidden>
              <img id="photo-preview-image" alt="Previsualización da fotografía seleccionada" />
              <figcaption>
                <strong id="photo-preview-name"></strong>
                <span id="photo-preview-size"></span>
              </figcaption>
            </figure>

            <button id="submit-photo" class="submit-photo" type="submit">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="13" height="13" rx="1.5" /><path d="m7 14 3-3 2.2 2.2 2-2L17 14M16 8h4v12H8v-3" /></svg>
              <span>Subir fotografía</span>
            </button>
          </div>

          <p class="review-note">
            <span aria-hidden="true">i</span>
            As fotografías quedarán pendentes de revisión. A administración decidirá se se conservan só no arquivo interno ou se se publican na galería pública, na galería privada do Portal ou en ambas.
          </p>
        </section>

        <p id="message" class="portal-message" role="status" hidden></p>
      </form>
    </main>
  </div>
</BaseLayout>

<script>
  import { getApp, getApps, initializeApp } from 'firebase/app';
  import { getAuth, onAuthStateChanged, signOut } from 'firebase/auth';

  const firebaseConfig = {
    apiKey: 'AIzaSyDrQY7NsaKpBfrSc8GqV3lUQDOIkecPZbs',
    authDomain: 'scpp-portal-privado.firebaseapp.com',
    projectId: 'scpp-portal-privado',
    storageBucket: 'scpp-portal-privado.firebasestorage.app',
    messagingSenderId: '506857659587',
    appId: '1:506857659587:web:a7ed36b22f044f5f639676'
  };

  const auth = getAuth(getApps().length ? getApp() : initializeApp(firebaseConfig));
  const form = document.querySelector('#photo-form');
  const loading = document.querySelector('#loading');
  const userEmail = document.querySelector('#user-email');
  const uploaderEmail = document.querySelector('#uploader-email');
  const message = document.querySelector('#message');
  const submit = document.querySelector('#submit-photo');
  const logout = document.querySelector('#photo-logout');
  const fileInput = document.querySelector('#photo-file');
  const fileName = document.querySelector('#selected-file-name');
  const dropZone = document.querySelector('#file-drop-zone');
  const preview = document.querySelector('#photo-preview');
  const previewImage = document.querySelector('#photo-preview-image');
  const previewName = document.querySelector('#photo-preview-name');
  const previewSize = document.querySelector('#photo-preview-size');
  let previewUrl = '';

  function showMessage(text, ok = false) {
    if (!(message instanceof HTMLElement)) return;
    message.textContent = text;
    message.dataset.ok = String(ok);
    message.hidden = false;
  }

  function updateSelectedFile(file) {
    if (previewUrl) {
      URL.revokeObjectURL(previewUrl);
      previewUrl = '';
    }

    if (fileName instanceof HTMLElement) {
      fileName.textContent = file
        ? 'Fotografía incorporada ao formulario'
        : 'Formatos permitidos: JPG, PNG, WebP · Tamaño máximo: 8 MB';
    }

    if (
      !(preview instanceof HTMLElement) ||
      !(previewImage instanceof HTMLImageElement) ||
      !(previewName instanceof HTMLElement) ||
      !(previewSize instanceof HTMLElement)
    ) return;

    if (!file) {
      preview.hidden = true;
      previewImage.removeAttribute('src');
      previewName.textContent = '';
      previewSize.textContent = '';
      return;
    }

    previewUrl = URL.createObjectURL(file);
    previewImage.src = previewUrl;
    previewName.textContent = file.name;
    previewSize.textContent = `${(file.size / (1024 * 1024)).toFixed(2)} MB`;
    preview.hidden = false;
  }

  function readBase64(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(String(reader.result || '').split(',')[1] || '');
      reader.onerror = () => reject(new Error('Non foi posible ler a fotografía.'));
      reader.readAsDataURL(file);
    });
  }

  async function hasValidAcceptance(user) {
    const idToken = await user.getIdToken(true);
    const response = await fetch('/api/aceptacion', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ idToken, accion: 'comprobarAceptacion', version: 'PRIVACIDADE-WEB-1.0' })
    });
    const result = await response.json().catch(() => null);
    return response.ok && result?.ok && result.aceptacionVixente === true;
  }

  onAuthStateChanged(auth, async (user) => {
    if (!user?.email) { window.location.replace('/portal/'); return; }
    try {
      if (!(await hasValidAcceptance(user))) { window.location.replace('/portal/'); return; }
      if (userEmail instanceof HTMLElement) userEmail.textContent = user.email;
      if (uploaderEmail instanceof HTMLInputElement) uploaderEmail.value = user.email;
      if (loading instanceof HTMLElement) loading.hidden = true;
      if (form instanceof HTMLFormElement) form.hidden = false;
    } catch {
      window.location.replace('/portal/');
    }
  });

  logout?.addEventListener('click', async () => {
    if (logout instanceof HTMLButtonElement) logout.disabled = true;
    await signOut(auth);
    window.location.href = '/portal/';
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput instanceof HTMLInputElement) updateSelectedFile(fileInput.files?.[0]);
  });

  if (dropZone instanceof HTMLElement && fileInput instanceof HTMLInputElement) {
    ['dragenter', 'dragover'].forEach((name) => {
      dropZone.addEventListener(name, (event) => {
        event.preventDefault();
        dropZone.classList.add('is-dragging');
      });
    });
    ['dragleave', 'drop'].forEach((name) => {
      dropZone.addEventListener(name, (event) => {
        event.preventDefault();
        dropZone.classList.remove('is-dragging');
      });
    });
    dropZone.addEventListener('drop', (event) => {
      const file = event.dataTransfer?.files?.[0];
      if (!file) return;
      const transfer = new DataTransfer();
      transfer.items.add(file);
      fileInput.files = transfer.files;
      updateSelectedFile(file);
    });
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;
    const user = auth.currentUser;
    const data = new FormData(form);
    const photoControl = form.elements.namedItem('foto');
    const file = photoControl instanceof HTMLInputElement ? photoControl.files?.[0] : null;

    if (!user?.email || !file) {
      showMessage('Selecciona unha fotografía e comproba a sesión.');
      return;
    }
    if (file.size > 8 * 1024 * 1024) {
      showMessage('A fotografía supera o máximo de 8 MB.');
      return;
    }
    if (submit instanceof HTMLButtonElement) {
      submit.disabled = true;
      submit.querySelector('span')?.replaceChildren('Subindo fotografía…');
    }

    try {
      const idToken = await user.getIdToken(true);
      const response = await fetch('/api/fotos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          idToken,
          accion: 'subirFoto',
          nomeFicheiro: file.name,
          tipo: file.type,
          base64: await readBase64(file),
          titulo: data.get('titulo'),
          peFoto: data.get('peFoto'),
          dataFoto: data.get('dataFoto'),
          anoAproximado: data.get('anoAproximado'),
          lugar: data.get('lugar'),
          autoria: data.get('autoria'),
          procedencia: data.get('procedencia'),
          concerto: data.get('concerto'),
          evento: data.get('evento'),
          confirmaDereitos: true
        })
      });
      const result = await response.json().catch(() => null);
      if (!response.ok || !result?.ok) throw new Error(result?.erro || 'Non foi posible enviar a fotografía.');
      form.reset();
      if (uploaderEmail instanceof HTMLInputElement) uploaderEmail.value = user.email;
      updateSelectedFile(null);
      showMessage(result.mensaxe || 'Fotografía enviada correctamente para revisión.', true);
    } catch (error) {
      showMessage(error instanceof Error ? error.message : 'Produciuse un erro ao enviar a fotografía.');
    } finally {
      if (submit instanceof HTMLButtonElement) {
        submit.disabled = false;
        submit.querySelector('span')?.replaceChildren('Subir fotografía');
      }
    }
  });
</script>

<style>
  .private-layout {
    display: grid;
    grid-template-columns: 282px minmax(0, 1fr);
    min-height: 100vh;
    background: #fff;
  }

  .upload-main {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.7rem clamp(1.5rem, 4vw, 4.2rem) 4rem;
  }

  .private-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .private-page-header h1 {
    margin: 0 0 .45rem;
    color: var(--color-principal);
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    letter-spacing: -.025em;
  }

  .private-page-header p {
    max-width: 760px;
    margin: 0;
    color: #5f5b58;
    font-size: .94rem;
  }

  .account-card {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    align-items: center;
    gap: .8rem;
    min-width: 245px;
    padding: .9rem 1rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #fff;
  }

  .account-card svg {
    width: 38px;
    height: 38px;
    fill: none;
    stroke: var(--color-principal);
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .account-card span {
    display: grid;
    gap: .12rem;
  }

  .account-card small {
    color: #5d5956;
    font-size: .7rem;
  }

  .account-card strong {
    max-width: 170px;
    overflow: hidden;
    color: var(--color-principal);
    font-size: .78rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .portal-state,
  .portal-message {
    padding: 1rem 1.1rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #faf9f7;
    color: #5d5956;
  }

  .portal-state[hidden],
  .upload-card[hidden],
  .portal-message[hidden] {
    display: none;
  }

  .upload-card {
    overflow: hidden;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #fff;
  }

  .upload-section {
    padding: 1.55rem 1.65rem;
  }

  .upload-section + .upload-section {
    border-top: 1px solid #e6e2de;
  }

  .upload-section h2 {
    margin: 0 0 1.25rem;
    color: var(--color-principal);
    font-size: 1rem;
  }

  .upload-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem 1.25rem;
  }

  .upload-field {
    display: grid;
    gap: .42rem;
    min-width: 0;
  }

  .upload-field-wide {
    grid-column: 1 / -1;
  }

  .upload-field > span {
    color: #35312f;
    font-size: .78rem;
    font-weight: 700;
  }

  .upload-field input,
  .upload-field textarea {
    width: 100%;
    min-height: 2.85rem;
    padding: .72rem .82rem;
    border: 1px solid #d4d0cc;
    border-radius: 3px;
    background: #fff;
    color: #393532;
    font: inherit;
    font-size: .88rem;
  }

  .upload-field textarea {
    min-height: 5.2rem;
    resize: vertical;
  }

  .upload-field input[readonly] {
    background: #faf9f7;
    color: #6b6662;
  }

  .upload-field input:focus,
  .upload-field textarea:focus {
    border-color: var(--color-principal);
    outline: 2px solid rgba(106, 27, 41, .08);
    outline-offset: 1px;
  }

  .rights-check {
    display: flex;
    align-items: flex-start;
    gap: .65rem;
    margin-top: 1.1rem;
    color: #5f5b58;
    font-size: .8rem;
    line-height: 1.45;
  }

  .rights-check input {
    margin-top: .18rem;
    accent-color: var(--color-principal);
  }

  .file-drop-zone {
    display: grid;
    justify-items: center;
    gap: .55rem;
    padding: 1.65rem 1.25rem 1rem;
    border: 1px dashed #c9c4bf;
    border-radius: 4px;
    background: #fff;
    text-align: center;
    transition: border-color .2s ease, background .2s ease;
  }

  .file-drop-zone.is-dragging {
    border-color: var(--color-principal);
    background: #fbf6f7;
  }

  .file-drop-zone > svg {
    width: 42px;
    height: 42px;
    fill: none;
    stroke: var(--color-principal);
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .file-drop-zone strong {
    color: #393532;
    font-size: .9rem;
  }

  .file-drop-zone > span,
  .file-drop-zone small {
    color: #77716c;
    font-size: .76rem;
  }

  #photo-file {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .file-picker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
    padding: .55rem 1.15rem;
    border: 1px solid var(--color-principal);
    border-radius: 3px;
    color: var(--color-principal);
    font-size: .8rem;
    font-weight: 700;
    cursor: pointer;
  }

  .file-picker:hover {
    background: #f8f1f2;
  }

  .photo-preview {
    display: grid;
    grid-template-columns: minmax(120px, 210px) minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    width: min(100%, 620px);
    margin: .85rem 0 0;
    padding: .8rem;
    border: 1px solid #ddd9d5;
    border-radius: 4px;
    background: #faf9f7;
    text-align: left;
  }

  .photo-preview[hidden] {
    display: none;
  }

  .photo-preview img {
    display: block;
    width: 100%;
    height: 130px;
    border-radius: 3px;
    background: #eeeae6;
    object-fit: contain;
  }

  .photo-preview figcaption {
    display: grid;
    gap: .3rem;
    min-width: 0;
  }

  .photo-preview figcaption strong {
    overflow: hidden;
    color: var(--color-principal);
    font-size: .82rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .photo-preview figcaption span {
    color: #77716c;
    font-size: .75rem;
  }

  .submit-photo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    width: 100%;
    min-height: 3rem;
    margin-top: .75rem;
    border: 0;
    border-radius: 3px;
    background: var(--color-principal);
    color: #fff;
    font: inherit;
    font-size: .9rem;
    font-weight: 800;
    cursor: pointer;
  }

  .submit-photo svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .submit-photo:hover:not(:disabled) {
    background: #54131f;
  }

  .submit-photo:disabled {
    cursor: wait;
    opacity: .65;
  }

  .review-note {
    display: flex;
    align-items: center;
    gap: .65rem;
    margin: 1rem 0 0;
    padding: .8rem .9rem;
    border: 1px solid #cfe0f2;
    border-radius: 4px;
    background: #f5faff;
    color: #2365a2;
    font-size: .78rem;
  }

  .review-note > span {
    display: grid;
    flex: 0 0 auto;
    width: 17px;
    height: 17px;
    place-items: center;
    border: 1px solid currentColor;
    border-radius: 50%;
    font-size: .66rem;
    font-weight: 800;
  }

  .portal-message {
    margin: 1rem;
    border-left: 3px solid var(--color-principal);
  }

  .portal-message[data-ok='true'] {
    border-color: #3d7950;
    background: #f2f8f3;
    color: #356345;
  }

  @media (max-width: 1050px) {
    .upload-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .private-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .upload-main {
      padding: 1.7rem 1rem 3rem;
    }

    .photo-preview {
      grid-template-columns: 1fr;
    }

    .private-page-header {
      flex-direction: column;
    }

    .account-card {
      width: 100%;
    }

    .upload-grid {
      grid-template-columns: 1fr;
    }

    .upload-field-wide {
      grid-column: auto;
    }

    .upload-section {
      padding: 1.2rem;
    }
  }
</style>
