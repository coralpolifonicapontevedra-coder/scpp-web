---
// Portada Oficial SCPP v1.1 - Importación Nativa de Assets
import { Image } from 'astro:assets';
import escudoImg from '../assets/Escudo.jpg';
import portadaImg from '../assets/Foto concierto centenario 09-04-2025.jpg';
---
<!DOCTYPE html>
<html lang="gl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sociedad Coral Polifónica de Pontevedra</title>
</head>
<body style="margin:0; padding:0; background-color: #fcfbf9; color: #111a2e; font-family: 'Playfair Display', Georgia, serif; line-height: 1.6;">

    <header style="background-color: #111a2e; color: #d4af37; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 3px solid #d4af37;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <Image src={escudoImg} alt="Escudo SCPP" style="height: 60px; width: auto; background-color: white; padding: 4px; border-radius: 4px; border: 1px solid #d4af37;" />
            <div>
                <h1 style="margin: 0; font-size: 1.4rem; letter-spacing: 1px;">Sociedad Coral Polifónica de Pontevedra</h1>
                <small style="color: #fff; opacity: 0.8;">Fundada en 1925</small>
            </div>
        </div>
        <nav style="font-family: sans-serif; font-size: 0.9rem;">
            <a href="#" style="color: #fff; text-decoration: none; margin-left: 1.5rem;">Inicio</a>
            <a href="#" style="color: #fff; text-decoration: none; margin-left: 1.5rem;">A Coral</a>
            <a href="#" style="color: #fff; text-decoration: none; margin-left: 1.5rem;">Axenda</a>
            <a href="#" style="color: #fff; text-decoration: none; margin-left: 1.5rem;">Contacto</a>
        </nav>
    </header>

    <section style="position: relative; background-color: #000; height: 60vh; overflow: hidden; display: flex; align-items: center; justify-content: center; color: white;">
        <Image src={portadaImg} alt="Concerto Centenario" style="position: absolute; width: 100%; height: 100%; object-fit: cover; opacity: 0.6;" />
        
        <div style="position: relative; text-align: center; padding: 2rem; max-width: 800px; background: rgba(17, 26, 46, 0.7); backdrop-filter: blur(3px); border: 1px solid #d4af37; border-radius: 4px;">
            <h2 style="font-size: 2.5rem; margin: 0 0 1rem 0; color: #d4af37;">Máis dun século de polifonía viva</h2>
            <p style="font-family: sans-serif; font-size: 1.1rem; margin: 0;">Benvidos ao novo portal oficial da Sociedad Coral Polifónica de Pontevedra. Un espazo para a nosa historia, o noso repertorio e os vindeiros concertos.</p>
        </div>
    </section>

    <main style="max-width: 900px; margin: 3rem auto; padding: 0 2rem; font-family: sans-serif; color: #333;">
        <h3 style="font-family: serif; font-size: 1.8rem; color: #111a2e; border-bottom: 1px solid #e0e0e0; padding-bottom: 0.5rem;">Próximos Eventos</h3>
        <p style="color: #666; font-style: italic;">Próximamente conectaremos esta sección directamente coa túa AppSheet Database para que se actualice de xeito automático.</p>
    </main>

</body>
</html>