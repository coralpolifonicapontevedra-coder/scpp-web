---
/* src/pages/index.astro */
import BaseLayout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import rosetonImg from "../assets/roseton.jpg";

---

<BaseLayout title="Inicio" lang="gl">
  <section class="hero-section">
    <div class="hero-box">
      <div class="hero-content">
        <div class="hero-logo-wrapper">
          <Image
            src={rosetonImg}
            alt="Rosetón SCPP"
            width={180}
            height={180}
            class="center-roseton"
          />
        </div>
        <h1>Sociedade Coral Polifónica de Pontevedra</h1>
        <div class="minimal-line"></div>
        <p class="hero-subtitle">
          Fundada en 1925 • Cen anos de patrimonio e polifonía en Galicia
        </p>
      </div>
    </div>
  </section>

  <section class="intro-section">
    <div class="container intro-content">
      <h2>Un Século de Canto</h2>
      <p>
        Unha das agrupacións corais máis antigas de Galicia e institución de
        referencia. Mantemos vivo o compromiso coa difusión do noso patrimonio a
        través da polifonía renacentista, a música medieval, sacra e a canción
        popular galega harmonizada.
      </p>
      <div class="intro-action">
        <a href="/benvida" class="btn-esencia">Descubre a nosa esencia</a>
      </div>
    </div>
  </section>


  <section class="agenda-section container">
    <div class="agenda-wrapper">
      <div class="agenda-title-row">
        <p class="agenda-eyebrow">Axenda</p>
        <h3>Próximos eventos</h3>
      </div>

      <div id="grid-proximos-eventos" class="grid-events" aria-live="polite">
        <p class="events-status">Cargando os próximos eventos…</p>
      </div>

      <div class="agenda-actions">
        <a href="/axenda" class="btn-agenda-link">Ver a axenda completa</a>
      </div>
    </div>
  </section>
  <section class="listen-section container" aria-labelledby="listen-title">
    <div class="listen-card">
      <div class="listen-copy">
        <p class="listen-eyebrow">Escoita a Coral</p>
        <h2 id="listen-title">Ave María · J. Busto</h2>
        <p>
          Interpretación no Concerto do Centenario, celebrado na igrexa de San
          Francisco de Pontevedra o 9 de abril de 2025.
        </p>
      </div>
      <button id="abrir-video" class="listen-button" type="button" aria-haspopup="dialog">
        <span class="play-mark" aria-hidden="true">▶</span>
        <span>
          <strong>Escoitar a interpretación</strong>
          <small>YouTube · 2:50</small>
        </span>
      </button>
    </div>
  </section>

  <dialog id="video-dialog" class="video-dialog" aria-labelledby="video-title">
    <button id="pechar-video" class="video-close" type="button" aria-label="Pechar vídeo">×</button>
    <h2 id="video-title">Ave María · J. Busto</h2>
    <div class="video-frame">
      <iframe
        id="youtube-player"
        title="Ave María de J. Busto interpretada pola Sociedade Coral Polifónica de Pontevedra"
        src=""
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
    <section class="more-videos" aria-labelledby="more-videos-title">
      <div class="more-videos-heading">
        <h3 id="more-videos-title">Máis interpretacións</h3>
        <div class="carousel-controls" aria-label="Desprazar interpretacións">
          <button id="videos-anteriores" type="button" aria-label="Ver vídeos anteriores">‹</button>
          <button id="videos-seguintes" type="button" aria-label="Ver vídeos seguintes">›</button>
        </div>
      </div>
      <div id="videos-strip" class="videos-strip">
        <button class="video-option" type="button" data-video="zma99Yv4iUw" data-title="Cantata Leucoiña · O Canto das augas">
          <img src="https://i.ytimg.com/vi/zma99Yv4iUw/hqdefault.jpg" alt="" loading="lazy" />
          <span>Cantata Leucoiña · O Canto das augas</span>
        </button>
        <button class="video-option is-current" type="button" data-video="I-Rwf49lWt8" data-title="Ave María · J. Busto" aria-pressed="true">
          <img src="https://i.ytimg.com/vi/I-Rwf49lWt8/hqdefault.jpg" alt="" loading="lazy" />
          <span>Ave María · J. Busto</span>
        </button>
        <button class="video-option" type="button" data-video="HYMNtIUTEHk" data-title="Laudate Dominum KV 339 · W. A. Mozart">
          <img src="https://i.ytimg.com/vi/HYMNtIUTEHk/hqdefault.jpg" alt="" loading="lazy" />
          <span>Laudate Dominum KV 339 · W. A. Mozart</span>
        </button>
        <button class="video-option" type="button" data-video="2M8pzcK9WQA" data-title="Deitadiño está nas pallas">
          <img src="https://i.ytimg.com/vi/2M8pzcK9WQA/hqdefault.jpg" alt="" loading="lazy" />
          <span>Deitadiño está nas pallas</span>
        </button>
      </div>
    </section>
  </dialog>

</BaseLayout>

<script>
  import { obterConcertos, dataISO } from '../lib/concertos';

  const normalizar = (valor = '') => String(valor)
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim()
    .toLowerCase();

  const corrixirErratas = (valor = '') => String(valor)
    .replaceAll('Liceo Casinto', 'Liceo Casino')
    .replaceAll('Real Acadademia', 'Real Academia')
    .replace(/\s+/g, ' ')
    .trim();

  const escapar = (valor = '') => corrixirErratas(valor)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');

  const dataEnGalego = (data) => {
    const iso = dataISO(data);
    const obxecto = new Date(`${iso}T12:00:00`);
    if (Number.isNaN(obxecto.getTime())) return escapar(data);
    const meses = ['xaneiro', 'febreiro', 'marzo', 'abril', 'maio', 'xuño', 'xullo', 'agosto', 'setembro', 'outubro', 'novembro', 'decembro'];
    return `${obxecto.getDate()} de ${meses[obxecto.getMonth()]} de ${obxecto.getFullYear()}`;
  };

  const horaLocal = (hora = '') => String(hora).trim().replace(/^(\d{1,2}:\d{2}):\d{2}$/, '$1');

  async function cargarProximosEventos() {
    const contedor = document.querySelector('#grid-proximos-eventos');
    if (!contedor) return;

    const concertos = await obterConcertos();
    const proximos = concertos
      .filter((evento) => normalizar(evento.estado) === 'confirmado')
      .sort((a, b) => dataISO(a.data).localeCompare(dataISO(b.data)))
      .slice(0, 3);

    if (!proximos.length) {
      contedor.innerHTML = '<p class="events-status">Neste momento non hai próximos eventos publicados.</p>';
      return;
    }

    contedor.innerHTML = proximos.map((evento) => {
      const localizacion = [evento.lugar, evento.cidade].filter(Boolean).join(' · ');
      const hora = horaLocal(evento.hora);
      const datosEvento = [hora, localizacion].filter(Boolean).map(escapar).join(' · ');
      return `<a class="event-card" href="/axenda" aria-label="Ver ${escapar(evento.nome)} na axenda">
        <time datetime="${escapar(dataISO(evento.data))}">${dataEnGalego(evento.data)}</time>
        <h4>${escapar(evento.nome)}</h4>
        ${datosEvento ? `<p class="event-meta">${datosEvento}</p>` : ''}
        ${evento.caracteristicas ? `<p class="event-description">${escapar(evento.caracteristicas)}</p>` : ''}
        <span class="event-link">Ver evento</span>
      </a>`;
    }).join('');
  }

  cargarProximosEventos();

  const dialogoVideo = document.querySelector('#video-dialog');
  const abrirVideo = document.querySelector('#abrir-video');
  const pecharVideo = document.querySelector('#pechar-video');
  const reproductor = document.querySelector('#youtube-player');
  const videoSrc = 'https://www.youtube-nocookie.com/embed/I-Rwf49lWt8?autoplay=1&rel=0';
  const tituloVideo = document.querySelector('#video-title');
  const tiraVideos = document.querySelector('#videos-strip');
  const anteriores = document.querySelector('#videos-anteriores');
  const seguintes = document.querySelector('#videos-seguintes');

  const reproducirVideo = (id, titulo) => {
    if (!reproductor || !id) return;
    reproductor.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
    reproductor.title = `${titulo} interpretada pola Sociedade Coral Polifónica de Pontevedra`;
    if (tituloVideo) tituloVideo.textContent = titulo;
    document.querySelectorAll('.video-option').forEach((opcion) => {
      const actual = opcion.dataset.video === id;
      opcion.classList.toggle('is-current', actual);
      opcion.setAttribute('aria-pressed', String(actual));
    });
  };

  const deterVideo = () => {
    if (reproductor) reproductor.src = '';
  };

  abrirVideo?.addEventListener('click', () => {
    if (!dialogoVideo || !reproductor) return;
    reproductor.src = videoSrc;
    dialogoVideo.showModal();
  });

  pecharVideo?.addEventListener('click', () => dialogoVideo?.close());
  dialogoVideo?.addEventListener('click', (evento) => {
    if (evento.target === dialogoVideo) dialogoVideo.close();
  });
  dialogoVideo?.addEventListener('close', deterVideo);

  document.querySelectorAll('.video-option').forEach((opcion) => {
    opcion.addEventListener('click', () => reproducirVideo(opcion.dataset.video, opcion.dataset.title));
  });
  anteriores?.addEventListener('click', () => tiraVideos?.scrollBy({ left: -320, behavior: 'smooth' }));
  seguintes?.addEventListener('click', () => tiraVideos?.scrollBy({ left: 320, behavior: 'smooth' }));
</script>

<style is:global>
  .hero-section {
    padding: 1.5rem 0;
  }
  .hero-box {
    background-color: var(--color-principal);
    min-height: 520px;
    margin: 0 2rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-content {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }
  .hero-logo-wrapper {
    width: 180px;
    height: 180px;
    margin-bottom: 2rem;
    overflow: hidden;
    border-radius: 50%;
    background: #090909;
  }
  .center-roseton {
    width: 100%;
    height: 100%;
    max-width: none;
    display: block;
    object-fit: cover;
    border-radius: 50%;
    transform: translateX(-2px) scale(1.035);
    transform-origin: center;
  }
  .hero-content h1 {
    color: var(--color-blanco);
    font-size: 2.8rem;
    line-height: 1.2;
    font-weight: 700;
  }
  .minimal-line {
    width: 60px;
    height: 2px;
    background-color: var(--color-acento);
    margin: 1.5rem 0;
  }
  .hero-subtitle {
    color: var(--color-acento);
    font-size: 1.1rem;
  }

  .intro-section {
    padding: 5rem 0;
    width: 100%;
    display: flex;
    justify-content: center;
    text-align: center;
  }
  .intro-content {
    max-width: 700px;
    margin: 0 auto;
  }
  .intro-content h2 {
    font-size: 2rem;
    margin-bottom: 1.2rem;
    color: var(--color-principal);
  }
  .intro-content p {
    font-size: 1.15rem;
    color: var(--color-texto);
    opacity: 0.9;
  }

  .intro-action {
    margin-top: 2.5rem;
  }

  .btn-esencia {
    color: var(--color-principal);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid var(--color-acento);
    padding-bottom: 4px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .btn-esencia:hover {
    color: var(--color-acento);
    border-color: var(--color-principal);
  }

  .listen-section {
    padding-bottom: 5rem;
  }
  .listen-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    background: var(--color-gris);
    border-left: 4px solid var(--color-acento);
    border-radius: 8px;
  }
  .listen-copy {
    max-width: 650px;
  }
  .listen-eyebrow {
    margin: 0 0 .25rem;
    color: var(--color-acento);
    font-size: .74rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .listen-copy h2 {
    margin: 0 0 .65rem;
    color: var(--color-principal);
    font-size: clamp(1.5rem, 3vw, 2rem);
  }
  .listen-copy > p:last-child {
    margin: 0;
    color: #5f5b56;
    line-height: 1.65;
  }
  .listen-button {
    display: flex;
    min-width: 245px;
    align-items: center;
    gap: .9rem;
    padding: 1rem 1.2rem;
    color: var(--color-blanco);
    background: var(--color-principal);
    border: 0;
    border-radius: 6px;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: background .2s ease, transform .2s ease;
  }
  .listen-button:hover {
    background: #7c2434;
    transform: translateY(-2px);
  }
  .play-mark {
    display: grid;
    width: 2.4rem;
    height: 2.4rem;
    flex: 0 0 2.4rem;
    place-items: center;
    padding-left: .15rem;
    color: var(--color-principal);
    background: var(--color-acento);
    border-radius: 50%;
    font-size: .8rem;
  }
  .listen-button strong,
  .listen-button small {
    display: block;
  }
  .listen-button strong {
    font-size: .9rem;
  }
  .listen-button small {
    margin-top: .15rem;
    color: #eadcbf;
    font-size: .72rem;
  }
  .video-dialog {
    width: min(92vw, 820px);
    padding: 2.75rem 1.25rem 1.25rem;
    background: var(--color-fondo);
    border: 0;
    border-radius: 8px;
  }
  .video-dialog::backdrop {
    background: rgba(20, 14, 15, .8);
  }
  .video-dialog h2 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
  }
  .video-close {
    position: absolute;
    top: .55rem;
    right: .75rem;
    width: 2rem;
    height: 2rem;
    color: var(--color-principal);
    background: transparent;
    border: 0;
    cursor: pointer;
    font-size: 1.8rem;
    line-height: 1;
  }
  .video-frame {
    position: relative;
    width: 100%;
    padding-top: 56.25%;
    overflow: hidden;
    background: #111;
    border-radius: 5px;
  }
  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .more-videos {
    margin-top: 1.25rem;
  }
  .more-videos-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: .75rem;
  }
  .more-videos-heading h3 {
    margin: 0;
    font-size: 1rem;
  }
  .carousel-controls {
    display: flex;
    gap: .4rem;
  }
  .carousel-controls button {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    padding: 0;
    color: var(--color-principal);
    background: var(--color-blanco);
    border: 1px solid rgba(106, 27, 41, .2);
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.35rem;
    line-height: 1;
  }
  .carousel-controls button:hover {
    color: var(--color-blanco);
    background: var(--color-principal);
  }
  .videos-strip {
    display: flex;
    gap: .8rem;
    padding: 0 0 .75rem;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-snap-type: x mandatory;
    scrollbar-color: var(--color-acento) var(--color-gris);
    scrollbar-width: thin;
  }
  .video-option {
    width: 190px;
    flex: 0 0 190px;
    padding: 0;
    overflow: hidden;
    color: var(--color-texto);
    background: var(--color-blanco);
    border: 1px solid rgba(106, 27, 41, .12);
    border-radius: 6px;
    cursor: pointer;
    scroll-snap-align: start;
    text-align: left;
  }
  .video-option.is-current {
    border: 2px solid var(--color-acento);
  }
  .video-option img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .video-option span {
    display: block;
    padding: .65rem .75rem .75rem;
    font-size: .78rem;
    font-weight: 650;
    line-height: 1.3;
  }
  .agenda-section {
    padding-bottom: 5rem;
  }
  .agenda-title-row {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-gris);
    padding-bottom: 1rem;
  }
  .agenda-eyebrow {
    margin: 0 0 .2rem;
    color: var(--color-acento);
    font-size: .74rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .agenda-wrapper h3 {
    margin: 0;
    color: var(--color-principal);
    font-size: clamp(1.55rem, 3vw, 2rem);
  }
  .grid-events {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  @media (max-width: 768px) {
    .listen-card {
      align-items: stretch;
      flex-direction: column;
    }
    .listen-button {
      width: 100%;
      min-width: 0;
    }
    .grid-events {
      grid-template-columns: 1fr;
    }
  }
  .event-card {
    display: flex;
    min-height: 255px;
    flex-direction: column;
    padding: 1.75rem;
    color: var(--color-texto);
    background: var(--color-blanco);
    border: 1px solid rgba(106, 27, 41, .12);
    border-left: 4px solid var(--color-acento);
    border-radius: 8px;
    box-shadow: 0 12px 30px rgba(64, 43, 30, .05);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 36px rgba(64, 43, 30, .09);
  }
  .event-card time {
    color: var(--color-acento);
    font-size: .82rem;
    font-weight: 700;
    text-transform: capitalize;
  }
  .event-card h4 {
    margin: .55rem 0 .9rem;
    color: var(--color-texto);
    font-size: clamp(1.2rem, 2vw, 1.45rem);
    line-height: 1.25;
  }
  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: .25rem .8rem;
    margin-bottom: .8rem;
    color: var(--color-principal);
    font-size: .9rem;
    font-weight: 650;
  }
  .event-description {
    color: #666;
    font-size: .92rem;
    line-height: 1.55;
  }
  .event-link {
    margin-top: auto;
    padding-top: 1.25rem;
    color: var(--color-principal);
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
  }
  .events-status {
    grid-column: 1 / -1;
    padding: 1.5rem;
    text-align: center;
    background: var(--color-gris);
    border-radius: 6px;
  }

  .agenda-actions {
    text-align: center;
    margin-top: 1rem;
  }
  .btn-agenda-link {
    display: inline-block;
    padding: 0.8rem 2.2rem;
    background-color: var(--color-principal);
    color: var(--color-blanco);
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }
  .btn-agenda-link:hover {
    background-color: var(--color-acento);
  }
</style>
