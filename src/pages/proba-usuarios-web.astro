---
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Proba de escritura web" lang="gl">
  <section class="test-page">
    <article class="test-card">
      <p class="eyebrow">Proba técnica temporal</p>
      <h1>Modificar UsuariosWeb</h1>
      <p class="intro">
        Esta proba só pode actualizar o campo <strong>Observacions</strong> do
        usuario autorizado. Non permite cambiar permisos, módulos nin datos
        doutras persoas.
      </p>

      <form id="usuarios-web-test" class="test-form">
        <div class="field">
          <label for="clave">Clave privada da proba</label>
          <input
            id="clave"
            name="clave"
            type="password"
            autocomplete="current-password"
            required
          />
        </div>

        <div class="field">
          <label for="observacions">Novo texto de observacións</label>
          <textarea
            id="observacions"
            name="observacions"
            rows="5"
            maxlength="500"
            required
          ></textarea>
          <p class="hint">Máximo 500 caracteres.</p>
        </div>

        <button type="submit">Realizar a proba</button>
      </form>

      <p id="resultado" class="result" role="status" aria-live="polite"></p>
    </article>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('usuarios-web-test');
      const result = document.getElementById('resultado');
      const submit = form?.querySelector('button[type="submit"]');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();

        const data = new FormData(form);
        result.textContent = 'Enviando a actualización…';
        result.className = 'result';
        submit.disabled = true;

        try {
          const response = await fetch('/.netlify/functions/usuarios-web-test', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({
              clave: data.get('clave'),
              observacions: data.get('observacions'),
            }),
          });

          const payload = await response.json();
          if (!response.ok || !payload?.ok) {
            throw new Error(payload?.erro || 'Non foi posible actualizar os datos');
          }

          result.textContent = payload.mensaxe;
          result.className = 'result is-success';
          form.reset();
        } catch (error) {
          result.textContent = error instanceof Error
            ? error.message
            : 'Produciuse un erro inesperado';
          result.className = 'result is-error';
        } finally {
          submit.disabled = false;
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .test-page {
    background: #f8f5ef;
    min-height: 72vh;
    padding: clamp(3.5rem, 8vw, 7rem) 1.25rem;
  }

  .test-card {
    background: #fff;
    border: 1px solid rgba(107, 29, 47, 0.18);
    margin: 0 auto;
    max-width: 660px;
    padding: clamp(2rem, 6vw, 4rem);
  }

  .eyebrow {
    color: var(--color-acento);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
  }

  h1 {
    color: var(--color-principal);
    font-size: clamp(2rem, 6vw, 3.25rem);
    line-height: 1.05;
    margin-bottom: 1.3rem;
  }

  .intro {
    color: #5f5a55;
    line-height: 1.7;
    margin-bottom: 2.2rem;
  }

  .test-form,
  .field {
    display: grid;
    gap: 0.65rem;
  }

  .test-form {
    gap: 1.5rem;
  }

  label {
    color: #332f2c;
    font-size: 0.9rem;
    font-weight: 700;
  }

  input,
  textarea {
    background: #fff;
    border: 1px solid #cfc8c1;
    border-radius: 3px;
    color: #25211f;
    font: inherit;
    padding: 0.85rem 0.95rem;
    width: 100%;
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-principal);
    outline: 3px solid rgba(107, 29, 47, 0.12);
  }

  textarea {
    resize: vertical;
  }

  .hint {
    color: #777069;
    font-size: 0.78rem;
  }

  button {
    background: var(--color-principal);
    border: 1px solid var(--color-principal);
    border-radius: 3px;
    color: #fff;
    cursor: pointer;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.95rem 1.2rem;
    text-transform: uppercase;
  }

  button:disabled {
    cursor: wait;
    opacity: 0.65;
  }

  .result {
    min-height: 1.6rem;
    margin-top: 1.3rem;
  }

  .result.is-success {
    color: #176b3a;
  }

  .result.is-error {
    color: #9b1c31;
  }
</style>
