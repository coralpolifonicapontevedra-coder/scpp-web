---
/* src/pages/distincions.astro */
import BaseLayout from '../layouts/Layout.astro';

const distincions = [
  {
    ano: '1950',
    data: '25 aniversario da Sociedade',
    titulo: 'Primeira Medalla de Prata da cidade de Pontevedra',
    entidade: 'Concello de Pontevedra',
    texto: 'Concedida con motivo do 25 aniversario da Coral. O alcalde Hevia Marinas entregou a medalla ao director Antonio Iglesias Vilarelle.',
    acto: 'A distinción recoñeceu a traxectoria artística e cultural desenvolvida pola Sociedade durante o seu primeiro cuarto de século.',
    destacada: false
  },
  {
    ano: '1975',
    data: 'Ano do 50 aniversario',
    titulo: 'Premio Amigos de Pontevedra 1975',
    entidade: 'Asociación de Amigos de Pontevedra',
    texto: 'Galardón concedido no ano do cincuentenario da Sociedade como recoñecemento á súa contribución continuada á cultura e á vida pública de Pontevedra.',
    acto: 'O premio incorporouse aos actos e recoñecementos vinculados á celebración dos cincuenta anos da entidade.',
    destacada: false
  },
  {
    ano: '2000–2001',
    data: 'Acordo do 18 e entrega do 20 de xaneiro de 2001',
    titulo: 'Premio Cidade de Pontevedra 2000',
    entidade: 'Concello de Pontevedra',
    texto: 'Concedido polo labor de recuperación e difusión da música e do canto coral, pola contribución de varias xeracións á identidade cultural de Pontevedra e pola intensa actividade desenvolvida durante o 75 aniversario e o Ano Castelao.',
    acto: 'A Corporación Municipal aprobou o premio por unanimidade na sesión extraordinaria do 18 de xaneiro de 2001. A Sesión de Honores e a entrega do diploma, da certificación e da placa conmemorativa celebráronse no Teatro Principal o 20 de xaneiro.',
    destacada: true
  },
  {
    ano: '2022',
    data: 'Agosto de 2022',
    titulo: 'Diploma de Amigos de Pontevedra',
    entidade: 'Asociación de Amigos de Pontevedra',
    texto: 'Novo recoñecemento público da entidade á traxectoria e á presenza da Polifónica na vida cultural da cidade.',
    acto: 'A entrega do diploma tivo lugar en agosto de 2022, coa participación de integrantes da Sociedade.',
    destacada: false
  },
  {
    ano: '2025',
    data: 'Emisión do 26 de marzo · presentación do 8 de abril',
    titulo: 'Selo conmemorativo e presentación oficial do centenario',
    entidade: 'Correos e Fábrica Nacional de Moneda e Timbre',
    texto: 'Correos dedicou á Sociedade un selo da serie «Efemérides» con motivo do centenario da súa fundación. A emisión reproduce o emblema da Coral sobre unha imaxe da agrupación en plena actuación.',
    acto: 'O selo foi emitido o 26 de marzo de 2025 e presentado oficialmente o 8 de abril no Edificio Castelao do Museo de Pontevedra, no marco da exposición do centenario. O acto concluíu co tradicional mataselos de honra. A emisión tivo unha tiraxe de 70.000 exemplares e un valor postal de 2 euros.',
    destacada: true
  },
  {
    ano: '2025',
    data: '4 de xuño de 2025',
    titulo: 'Pontevedreses do Ano — Música e Cultura',
    entidade: 'Diario de Pontevedra',
    texto: 'A Sociedade foi distinguida na categoría de Música e Cultura no ano do seu centenario, como recoñecemento a cen anos de actividade artística e de compromiso coa cidade.',
    acto: 'A gala celebrouse no Auditorio de Afundación de Pontevedra. A Coral pechou o acto interpretando Si vas a San Benitiño, de Antonio Blanco Porto.',
    destacada: true
  },
  {
    ano: '2025',
    data: '11 de decembro de 2025',
    titulo: 'Premio Otero Pedrayo 2025',
    entidade: 'As catro deputacións galegas e a Fundación Otero Pedrayo',
    texto: 'Un dos grandes recoñecementos do centenario, concedido pola contribución continuada da Sociedade á preservación, difusión e dignificación do patrimonio musical e cultural galego.',
    acto: 'A cerimonia celebrouse no Salón de Plenos do Pazo da Deputación de Pontevedra. Foi conducida pola xornalista Belén López e incluíu a laudatio de Ángeles Tilve, directora do Museo de Pontevedra, intervencións institucionais e unha audición da Coral.',
    destacada: true
  },
  {
    ano: '2025',
    data: 'Acordo do 1 de febreiro · entrega do 13 de decembro',
    titulo: 'Medalla de Ouro «Marcial del Adalid»',
    entidade: 'Real Academia Galega de Belas Artes',
    texto: 'Concedida pola traxectoria acreditada dun século de actividade artística do máis alto nivel e polo lugar da Sociedade entre as institucións musicais históricas de Galicia.',
    acto: 'A Real Academia acordou a concesión o 1 de febreiro de 2025. O diploma e a medalla entregáronse o 13 de decembro no Edificio Castelao do Museo de Pontevedra. A académica Rosa Cedrón pronunciou a laudatio e, despois da entrega, a Coral ofreceu un recital.',
    detalle: 'Na súa intervención, Rosa Cedrón realizou un percorrido pola historia centenaria da Sociedade, desde a fundación e a primeira presentación pública ata a súa proxección dentro e fóra de Galicia. Subliñou especialmente o papel da Coral na difusión da polifonía clásica e sacra e da música popular galega harmonizada, así como a contribución das sucesivas xeracións de cantores, direccións e persoas vinculadas á entidade.',
    repertorio: 'O recital incluíu Si vas a San Benitiño, de Antonio Blanco Porto; Unha noite na eira do trigo, de M. Ángel Viro con texto de Curros Enríquez; e Deitadiño está nas pallas, popular con arranxo de Luís Bolón.',
    documento: '/docs/distincions/laudatio-marcial-del-adalid.pdf',
    documentoTexto: 'Ler a laudatio completa',
    destacada: true
  },
  {
    ano: '2026',
    data: '28 de marzo de 2026',
    titulo: 'Vieira de Honra á Calidade Artística',
    entidade: 'Fundación Cultural da Vieira · Enxebre Orde da Vieira',
    texto: 'Distinción concedida á Sociedade pola súa traxectoria e pola súa contribución á difusión da música coral galega e da galeguidade.',
    acto: 'A entrega tivo lugar en Madrid durante o LVIII Cabido Xeral da Enxebre Orde da Vieira, celebrado o 28 de marzo de 2026. O recoñecemento foi recibido no marco dun encontro dedicado a distinguir persoas e entidades que manteñen viva e prestixian a cultura galega.',
    documento: '/docs/distincions/diploma-vieira-de-honra.pdf',
    documentoTexto: 'Ver o diploma da Vieira de Honra',
    destacada: true
  }
];

const fitosCentenario = [
  {
    titulo: 'Un século recoñecido',
    texto: 'Os galardóns recibidos en 2025 fixeron visible, desde ámbitos xornalísticos, institucionais e académicos, a dimensión musical, cultural e patrimonial da Sociedade.'
  },
  {
    titulo: 'A música dentro das cerimonias',
    texto: 'A Coral non foi unha presenza pasiva nos actos: participou musicalmente nas entregas de Pontevedreses do Ano, do Premio Otero Pedrayo e da Medalla Marcial del Adalid.'
  },
  {
    titulo: 'Documentación aberta',
    texto: 'A relación seguirá completándose con diplomas, fotografías, actas e datas exactas procedentes do arquivo da Sociedade e doutras institucións.'
  }
];
---

<BaseLayout title="Distincións | Sociedade Coral Polifónica de Pontevedra" lang="gl">
  <main class="distincions-page">
    <header class="distincions-hero">
      <div class="hero-content">
        <p class="eyebrow">Recoñecementos institucionais</p>
        <h1>Distincións</h1>
        <p class="hero-lead">
          Premios, medallas e homenaxes que recoñecen máis dun século de compromiso
          coa música, coa cultura galega e coa cidade de Pontevedra.
        </p>
        <a class="hero-link" href="#relacion">Consultar a relación <span aria-hidden="true">↓</span></a>
      </div>
    </header>


    <section class="intro-section">
      <p class="section-kicker">Centenario · 2025–2026</p>
      <h2>Recoñecementos dun século de música</h2>
      <p>
        Moitas destas distincións forman parte dos actos do centenario.
        Concertos, conferencias, exposicións e homenaxes poden consultarse
        na páxina específica da celebración.
      </p>

      <a href="/centenario" class="btn-centenario">
        Visitar a páxina do centenario
      </a>
    </section>

    <section class="intro-section">
      <p class="section-kicker">Memoria institucional</p>
      <h2>O recoñecemento a unha obra colectiva</h2>
      <p>
        Cada distinción pertence ás xeracións de cantoras, cantores, direccións musicais,
        xuntas directivas e persoas colaboradoras que fixeron posible a continuidade da
        Sociedade Coral Polifónica de Pontevedra desde 1925.
      </p>
    </section>

    <section id="relacion" class="awards-section" aria-label="Relación de distincións">
      <div class="awards-list">
        {distincions.map((item, index) => (
          <article class={`award-card ${item.destacada ? 'featured' : ''}`}>
            <div class="award-index">{String(index + 1).padStart(2, '0')}</div>

            <div class="award-content">
              <div class="award-meta">
                <span>{item.ano}</span>
                <span>{item.data}</span>
              </div>

              <h2>{item.titulo}</h2>
              <p class="award-entity">{item.entidade}</p>
              <p>{item.texto}</p>

              <div class="award-event">
                <strong>Acto e documentación</strong>
                <p>{item.acto}</p>
              </div>

              {item.detalle && (
                <details class="award-details">
                  <summary>Resumo da laudatio</summary>
                  <p>{item.detalle}</p>
                  {item.repertorio && (
                    <p class="award-repertoire"><strong>Recital:</strong> {item.repertorio}</p>
                  )}
                </details>
              )}

              {item.documento && (
                <a
                  class="document-link"
                  href={item.documento}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {item.documentoTexto}
                  <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="centenary-section">
      <header class="section-heading">
        <p class="section-kicker">Centenario · 2025</p>
        <h2>Un ano de especial significado</h2>
        <p>
          Os recoñecementos do centenario tiveron unha dimensión institucional,
          pero tamén musical: en cada acto, a Sociedade volveu facer da súa voz
          a mellor expresión da súa historia.
        </p>
      </header>

      <div class="centenary-grid">
        {fitosCentenario.map((item, index) => (
          <article class="centenary-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.titulo}</h3>
            <p>{item.texto}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="documentation-note">
      <p class="section-kicker">Memoria documental</p>
      <h2>Premios que forman parte do noso patrimonio</h2>
      <p>
        Diplomas, medallas, selos, programas e fotografías conservan a memoria
        material destes recoñecementos e permiten seguir ampliando a historia
        institucional da Sociedade.
      </p>
      <a href="/acoral" class="back-link">Volver a A Coral <span aria-hidden="true">→</span></a>
    </section>
  </main>
</BaseLayout>

<style>
  .distincions-page {
    --wine: var(--color-principal, #5c1926);
    --gold: var(--color-acento, #a3821a);
    --ink: #201d1d;
    --muted: #6f6965;
    --paper: #f7f5f0;
    --line: #ded8ce;
    background: #fff;
    color: var(--ink);
    padding-bottom: 7rem;
  }

  .distincions-hero {
    min-height: 390px;
    display: grid;
    place-items: center;
    padding: 5rem 1.5rem 6rem;
    background:
      radial-gradient(circle at 75% 20%, rgba(225, 202, 123, 0.2), transparent 30%),
      linear-gradient(135deg, #4b111d, #6e2130);
    color: white;
    text-align: center;
  }

  .hero-content {
    width: min(820px, 100%);
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 1rem;
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .distincions-hero .eyebrow {
    color: #e1ca7b;
  }

  .distincions-hero h1 {
    margin: 0;
    color: #fffaf1;
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .hero-lead {
    max-width: 680px;
    margin: 1.5rem auto 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    line-height: 1.75;
  }

  .hero-link,
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .hero-link {
    margin-top: 2rem;
    color: white;
  }

  .hero-link span,
  .back-link span {
    color: #e1ca7b;
    font-size: 1.05rem;
  }

  .intro-section,
  .awards-section,
  .centenary-section,
  .documentation-note {
    width: min(980px, calc(100% - 3rem));
    margin-right: auto;
    margin-left: auto;
  }

  .intro-section {
    max-width: 760px;
    padding: 5.5rem 0 4rem;
    text-align: center;
  }

  .intro-section h2,
  .section-heading h2,
  .documentation-note h2 {
    margin: 0;
    color: var(--wine);
    font-size: clamp(2.1rem, 5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .intro-section > p:last-child,
  .section-heading > p:last-child,
  .documentation-note > p {
    margin: 1.4rem auto 0;
    color: var(--muted);
    font-size: 1.04rem;
    line-height: 1.85;
  }

  .awards-list {
    display: grid;
    gap: 1.35rem;
  }

  .award-card {
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 1.5rem;
    padding: 2.2rem;
    border: 1px solid var(--line);
    background: white;
  }

  .award-card:nth-child(even) {
    background: var(--paper);
    border-left: 4px solid var(--gold);
  }

  .award-card:nth-child(odd) {
    background: white;
    border-left: 4px solid transparent;
  }

  .award-index {
    color: var(--gold);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding-top: 0.35rem;
  }

  .award-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.1rem;
    margin-bottom: 0.85rem;
  }

  .award-meta span {
    color: var(--gold);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .award-content h2 {
    margin: 0;
    color: var(--wine);
    font-size: 1.5rem;
    line-height: 1.25;
  }

  .award-content > p,
  .award-event p,
  .centenary-card p {
    color: #4c4744;
    line-height: 1.8;
  }

  .award-entity {
    margin-top: 0.55rem;
    color: var(--ink) !important;
    font-weight: 700;
  }

  .award-event {
    margin-top: 1.25rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }

  .award-event strong {
    color: var(--wine);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .award-event p {
    margin-bottom: 0;
    font-size: 0.93rem;
  }

  .award-details {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid var(--line);
  }

  .award-details summary {
    color: var(--wine);
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .award-details p {
    color: #4c4744;
    line-height: 1.75;
  }

  .award-repertoire {
    padding-top: 0.8rem;
    border-top: 1px solid var(--line);
    font-size: 0.93rem;
  }

  .document-link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--gold);
    color: var(--wine);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .document-link:hover,
  .document-link:focus-visible {
    background: var(--wine);
    color: white;
  }

  .document-link span {
    color: var(--gold);
    font-size: 1rem;
  }

  .centenary-section {
    padding-top: 6rem;
  }

  .section-heading {
    max-width: 760px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .centenary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .centenary-card {
    padding: 2rem;
    background: var(--wine);
  }

  .centenary-card > span {
    color: #e1ca7b;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .centenary-card h3 {
    margin: 1.1rem 0 0;
    color: white;
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .centenary-card p {
    color: rgba(255, 255, 255, 0.78);
  }

  .documentation-note {
    margin-top: 5rem;
    padding: 4rem 2.5rem;
    background: var(--paper);
    text-align: center;
  }

  .back-link {
    margin-top: 2rem;
    color: var(--wine);
  }

  .back-link span {
    color: var(--gold);
  }

  
  .btn-centenario {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.85rem 2rem;
    background: var(--wine);
    color: white;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    border-radius: 4px;
  }

  .btn-centenario:hover {
    background: var(--gold);
  }


  @media (max-width: 760px) {
    .centenary-grid {
      grid-template-columns: 1fr;
    }

    .award-card {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      padding: 1.6rem;
    }

    .award-index {
      padding-top: 0;
    }
  }

  @media (max-width: 520px) {
    .distincions-hero {
      min-height: 360px;
      padding: 4rem 1.2rem 5rem;
    }

    .intro-section,
    .awards-section,
    .centenary-section,
    .documentation-note {
      width: min(100% - 2rem, 980px);
    }

    .documentation-note {
      padding: 3rem 1.4rem;
    }
  }
</style>
