---
/* src/pages/axenda.astro */
import BaseLayout from '../layouts/Layout.astro';
---

<BaseLayout title="Axenda" lang="gl">
  <main class="container agenda-page">
    <header class="agenda-header">
      <p class="eyebrow">Programación</p>
      <h1>Axenda</h1>
      <div class="section-line-center"></div>
      <p>
        Consulta os próximos concertos da Sociedade Coral Polifónica de Pontevedra
        e descubre tamén a memoria das actuacións xa finalizadas.
      </p>
    </header>

    <div id="aviso-carga" class="loading" role="status">Cargando a programación…</div>

    <section id="proximos" class="agenda-block" hidden>
      <div class="section-heading">
        <p class="eyebrow">Vindeiras actuacións</p>
        <h2>Próximos concertos</h2>
      </div>
      <div id="lista-proximos" class="concert-list"></div>
    </section>

    <section id="aprazados" class="agenda-block" hidden>
      <div class="section-heading">
        <p class="eyebrow">Información</p>
        <h2>Concertos aprazados</h2>
      </div>
      <div id="lista-aprazados" class="concert-list"></div>
    </section>

    <section id="realizados" class="agenda-block" hidden>
      <div class="section-heading">
        <p class="eyebrow">Arquivo recente</p>
        <h2>Concertos finalizados</h2>
      </div>
      <div id="lista-realizados" class="historical-list"></div>
    </section>

    <div id="sen-resultados" class="empty-state" hidden>
      Neste momento non hai concertos publicados na axenda.
    </div>
  </main>

  <dialog id="visor-cartel" class="poster-dialog" aria-label="Cartel ampliado">
    <button type="button" class="poster-close" aria-label="Pechar cartel">×</button>
    <img id="cartel-ampliado" src="" alt="" />
  </dialog>
</BaseLayout>

<script>
  const URL_CONCERTOS = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSX8BEJ-hrubqEtaZ1zZaLSy7LoxaDQOuQuqR2ior7TZErtBGL5bJG0B_AK5Dp8eFeTDb3Pmpqh7Hnu/pub?gid=1098509641&single=true&output=csv';
  const URL_PROGRAMAS = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vTMm4Z45Bcfz_-AEwcA6lNmttLAjJEOxXpTFmlnLwtRCoSIF7xlCP-LEdlfLoMYkbOnAefC7I9G9Cec/pub?gid=1925601694&single=true&output=csv';
  const URL_REPERTORIO = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSuYtrIlKLbU1QkH7fP2zbKQQYFV6kvACLLFBZrJ7cC8t54jAsrTDWvL_x7fko9Hw71oKIoYyBcjNF3/pub?gid=984049442&single=true&output=csv';

  const normalizar = (valor = '') => String(valor)
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim()
    .toLowerCase();

  const corrixirErratas = (valor = '') => String(valor)
    .replaceAll('Liceo Casinto', 'Liceo Casino')
    .replaceAll('Real Acadademia', 'Real Academia');

  const escapar = (valor = '') => corrixirErratas(valor)
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');

  const verdadeiro = (valor = '') =>
    ['true', 'si', 'sí', 'yes', '1', 'verdadeiro'].includes(normalizar(valor));

  function parseCSV(texto) {
    const filas = [];
    let fila = [];
    let campo = '';
    let entreComillas = false;

    for (let i = 0; i < texto.length; i++) {
      const c = texto[i];
      const seguinte = texto[i + 1];
      if (c === '"' && entreComillas && seguinte === '"') {
        campo += '"';
        i++;
      } else if (c === '"') {
        entreComillas = !entreComillas;
      } else if (c === ',' && !entreComillas) {
        fila.push(campo);
        campo = '';
      } else if ((c === '\n' || c === '\r') && !entreComillas) {
        if (c === '\r' && seguinte === '\n') i++;
        fila.push(campo);
        if (fila.some((valor) => valor.trim() !== '')) filas.push(fila);
        fila = [];
        campo = '';
      } else {
        campo += c;
      }
    }

    if (campo || fila.length) {
      fila.push(campo);
      filas.push(fila);
    }

    const cabeceiras = (filas.shift() || []).map(normalizar);
    return filas.map((valores) =>
      Object.fromEntries(cabeceiras.map((cab, i) => [cab, (valores[i] || '').trim()])),
    );
  }

  const valor = (fila, ...nomes) => {
    for (const nome of nomes) {
      const atopado = fila[normalizar(nome)];
      if (atopado !== undefined && atopado !== '') return atopado;
    }
    return '';
  };

  const dataISO = (data) => {
    const partes = String(data).split(/[\/-]/).map(Number);
    if (partes.length !== 3 || partes.some(Number.isNaN)) return String(data);
    if (partes[0] > 31) {
      return `${partes[0]}-${String(partes[1]).padStart(2, '0')}-${String(partes[2]).padStart(2, '0')}`;
    }
    return `${partes[2]}-${String(partes[1]).padStart(2, '0')}-${String(partes[0]).padStart(2, '0')}`;
  };

  const dataLocal = (data) => {
    const iso = dataISO(data);
    const obxecto = new Date(`${iso}T12:00:00`);
    if (Number.isNaN(obxecto.getTime())) return escapar(data);
    return new Intl.DateTimeFormat('gl-ES', {
      day: 'numeric', month: 'long', year: 'numeric',
    }).format(obxecto);
  };

  const enlacePublico = (valor, tipo = 'documento') => {
    const ruta = String(valor || '').trim().replaceAll('\\', '/');
    if (!ruta) return '';
    if (/^https?:\/\//i.test(ruta) || ruta.startsWith('/')) return ruta;
    const nomeFicheiro = ruta.split('/').filter(Boolean).pop();
    if (!nomeFicheiro) return '';
    if (tipo === 'cartel') return `/img/concertos/${encodeURIComponent(nomeFicheiro)}`;
    return '';
  };

  async function lerCSV(url) {
    const resposta = await fetch(url, { cache: 'no-store' });
    if (!resposta.ok) throw new Error(`Erro ${resposta.status}`);
    return parseCSV(await resposta.text());
  }

  const renderPrograma = (programa) => {
    if (!programa.length) return '';
    return `<details class="programa"><summary>Ver programa</summary><ol>${programa.map((item) => `
      <li>
        <div class="obra-linea">
          <span class="obra">${escapar(item.obra)}</span>
          ${item.autor ? `<span class="autor">${escapar(item.autor)}</span>` : ''}
        </div>
        ${item.solista ? `<small><strong>Solista:</strong> ${escapar(item.solista)}</small>` : ''}
        ${item.notas ? `<small>${escapar(item.notas)}</small>` : ''}
      </li>`).join('')}</ol></details>`;
  };

  const renderDocumentos = (concerto) => {
    const documentos = [
      ['Tríptico', enlacePublico(concerto.triptico)],
      ['Prensa', enlacePublico(concerto.prensa)],
    ].filter(([, url]) => url);
    if (!documentos.length) return '';
    return `<div class="documentos">${documentos.map(([nome, url]) =>
      `<a href="${escapar(url)}" target="_blank" rel="noopener noreferrer">${nome}</a>`
    ).join('')}</div>`;
  };

  const renderCartel = (concerto) => {
    const cartelOrixinal = enlacePublico(concerto.cartel, 'cartel');
    if (!cartelOrixinal) return '';
    const cartel = /\.pdf(?:$|\?)/i.test(cartelOrixinal)
      ? cartelOrixinal.replace(/\.pdf(?=$|\?)/i, '.jpg')
      : cartelOrixinal;
    const alt = `Cartel de ${concerto.nome}`;
    return `<button type="button" class="poster-thumb" data-poster="${escapar(cartel)}" data-alt="${escapar(alt)}" aria-label="Ampliar ${escapar(alt)}">
      <img src="${escapar(cartel)}" alt="${escapar(alt)}" loading="lazy" />
      <span>Ampliar cartel</span>
    </button>`;
  };

  const renderConcerto = (concerto, etiqueta = 'Concerto confirmado') => {
    const localizacion = [concerto.lugar, concerto.cidade].filter(Boolean).join(' · ');
    return `<article class="concert-card ${concerto.destacadoWeb ? 'is-featured' : ''}">
      <div class="concert-content">
        <span class="concert-tag">${escapar(etiqueta)}</span>
        <time datetime="${escapar(dataISO(concerto.data))}">${dataLocal(concerto.data)}</time>
        <h3>${escapar(concerto.nome)}</h3>
        <div class="concert-meta">
          ${concerto.hora ? `<span><strong>Hora</strong> ${escapar(concerto.hora)}</span>` : ''}
          ${localizacion ? `<span><strong>Lugar</strong> ${escapar(localizacion)}</span>` : ''}
        </div>
        ${concerto.caracteristicas ? `<p class="description">${escapar(concerto.caracteristicas)}</p>` : ''}
        ${renderPrograma(concerto.programa)}
        ${renderDocumentos(concerto)}
      </div>
      ${renderCartel(concerto)}
    </article>`;
  };

  const renderRealizado = (concerto) => {
    const localizacion = [concerto.lugar, concerto.cidade].filter(Boolean).join(' · ');
    return `<article class="historical-item">
      <div class="historical-main">
        <div class="historical-content">
          <time datetime="${escapar(dataISO(concerto.data))}">${dataLocal(concerto.data)}</time>
          <h3>${escapar(concerto.nome)}</h3>
          ${localizacion ? `<p>${escapar(localizacion)}</p>` : ''}
        </div>
        ${renderCartel(concerto)}
      </div>
      ${renderPrograma(concerto.programa)}
      ${renderDocumentos(concerto)}
    </article>`;
  };

  function activarVisor() {
    const dialogo = document.querySelector('#visor-cartel');
    const imaxe = document.querySelector('#cartel-ampliado');
    const pechar = dialogo?.querySelector('.poster-close');
    if (!dialogo || !imaxe || !pechar) return;

    document.addEventListener('click', (evento) => {
      const boton = evento.target.closest('.poster-thumb');
      if (!boton) return;
      imaxe.src = boton.dataset.poster || '';
      imaxe.alt = boton.dataset.alt || 'Cartel ampliado';
      dialogo.showModal();
    });

    pechar.addEventListener('click', () => dialogo.close());
    dialogo.addEventListener('click', (evento) => {
      if (evento.target === dialogo) dialogo.close();
    });
  }

  async function cargarAxenda() {
    const aviso = document.querySelector('#aviso-carga');
    const senResultados = document.querySelector('#sen-resultados');

    try {
      const [concertosRaw, programasRaw, repertorioRaw] = await Promise.all([
        lerCSV(URL_CONCERTOS), lerCSV(URL_PROGRAMAS), lerCSV(URL_REPERTORIO),
      ]);

      const obras = new Map(repertorioRaw.map((fila) => [
        valor(fila, 'Id', 'Row ID'),
        {
          nome: valor(fila, 'Nome', 'NomeObra', 'Obra', 'Título', 'Titulo'),
          autor: valor(fila, 'Autor', 'Compositor'),
        },
      ]));

      const concertos = concertosRaw.map((fila) => {
        const id = valor(fila, 'Id', 'Row ID');
        const programa = programasRaw
          .filter((item) => valor(item, 'Id_Conciertos', 'Id_Concertos') === id)
          .map((item) => {
            const idObra = valor(item, 'Id_Obras');
            const obra = obras.get(idObra) || {};
            return {
              orde: Number(valor(item, 'Orde')) || 999,
              obra: obra.nome || idObra,
              autor: obra.autor || '',
              notas: valor(item, 'Notas'),
              solista: valor(item, 'Solista'),
            };
          })
          .sort((a, b) => a.orde - b.orde);

        return {
          id,
          data: valor(fila, 'Data'),
          nome: valor(fila, 'Nome'),
          cidade: valor(fila, 'Cidade'),
          lugar: valor(fila, 'Lugar'),
          caracteristicas: valor(fila, 'Características', 'Caracteristicas'),
          cartel: valor(fila, 'Cartel'),
          triptico: valor(fila, 'Triptico', 'Tríptico'),
          prensa: valor(fila, 'Prensa'),
          hora: valor(fila, 'Hora'),
          mostrarWeb: verdadeiro(valor(fila, 'Mostrar_Web')),
          destacadoWeb: verdadeiro(valor(fila, 'Destacado_Web')),
          estado: normalizar(valor(fila, 'Estado')),
          programa,
        };
      }).filter((c) => c.mostrarWeb && c.id && c.data && c.nome);

      const confirmados = concertos
        .filter((c) => c.estado === 'confirmado')
        .sort((a, b) => Number(b.destacadoWeb) - Number(a.destacadoWeb) || dataISO(a.data).localeCompare(dataISO(b.data)));
      const aprazados = concertos
        .filter((c) => c.estado === 'aprazado' || c.estado === 'aplazado')
        .sort((a, b) => dataISO(a.data).localeCompare(dataISO(b.data)));
      const realizados = concertos
        .filter((c) => c.estado === 'realizado')
        .sort((a, b) => dataISO(b.data).localeCompare(dataISO(a.data)));

      if (confirmados.length) {
        document.querySelector('#lista-proximos').innerHTML = confirmados.map((c) => renderConcerto(c)).join('');
        document.querySelector('#proximos').hidden = false;
      }
      if (aprazados.length) {
        document.querySelector('#lista-aprazados').innerHTML = aprazados.map((c) => renderConcerto(c, 'Concerto aprazado')).join('');
        document.querySelector('#aprazados').hidden = false;
      }
      if (realizados.length) {
        document.querySelector('#lista-realizados').innerHTML = realizados.map(renderRealizado).join('');
        document.querySelector('#realizados').hidden = false;
      }

      aviso.hidden = true;
      senResultados.hidden = Boolean(confirmados.length || aprazados.length || realizados.length);
    } catch (erro) {
      console.error(erro);
      aviso.textContent = 'Non foi posible cargar a axenda neste momento. Téntao de novo máis tarde.';
      aviso.classList.add('error');
    }
  }

  activarVisor();
  cargarAxenda();
</script>

<style>
  .agenda-page { padding: 4rem 1.25rem 6rem; }
  .agenda-header { max-width: 760px; margin: 0 auto 4.5rem; text-align: center; }
  .agenda-header h1 { margin: .2rem 0; color: var(--color-principal); font-size: clamp(2rem, 5vw, 3rem); }
  .agenda-header > p:last-child { line-height: 1.7; opacity: .82; }
  .eyebrow { margin: 0; color: var(--color-acento); font-size: .76rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; }
  .section-line-center { width: 48px; height: 2px; margin: 1.1rem auto 1.5rem; background: var(--color-acento); }
  .agenda-block { margin-top: 5rem; }
  .section-heading { margin-bottom: 2rem; border-bottom: 1px solid var(--color-gris); padding-bottom: 1rem; }
  .section-heading h2 { margin: .25rem 0 0; color: var(--color-principal); font-size: clamp(1.5rem, 3vw, 2rem); }
  .concert-list, .historical-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1.5rem; align-items: stretch; }
  .concert-card { display: grid; grid-template-columns: minmax(0, 1fr) 150px; gap: 1.5rem; align-items: start; height: 100%; padding: clamp(1.5rem, 3vw, 2rem); background: var(--color-gris); border: 1px solid rgba(106,27,41,.1); border-radius: 8px; box-shadow: 0 12px 30px rgba(64,43,30,.06); }
  .concert-card.is-featured { border-left: 4px solid var(--color-acento); }
  .concert-tag { display: inline-block; margin-bottom: 1rem; color: var(--color-principal); font-size: .72rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; }
  .concert-content time, .historical-item time { display: block; color: var(--color-acento); font-size: .92rem; font-weight: 650; text-transform: capitalize; }
  .concert-content h3 { margin: .45rem 0 1.25rem; color: var(--color-texto); font-size: clamp(1.45rem, 3vw, 2rem); }
  .concert-meta { display: flex; flex-wrap: wrap; gap: .65rem 1.7rem; margin-bottom: 1.4rem; }
  .concert-meta span { font-size: .96rem; }
  .concert-meta strong { margin-right: .35rem; color: var(--color-principal); }
  .description { max-width: 720px; line-height: 1.7; opacity: .84; }
  .poster-thumb { display: block; width: 150px; max-width: 150px; margin: 0; padding: 0; border: 0; background: transparent; cursor: zoom-in; text-align: center; }
  .poster-thumb img { display: block; width: 150px; max-width: 150px; height: auto; max-height: 210px; object-fit: contain; background: #fff; border: 1px solid rgba(0,0,0,.1); border-radius: 3px; }
  .poster-thumb span { display: block; margin-top: .45rem; color: var(--color-principal); font-size: .72rem; font-weight: 700; }
  .programa { margin-top: 1.6rem; border-top: 1px solid rgba(0,0,0,.1); padding-top: 1rem; }
  .programa summary { cursor: pointer; color: var(--color-principal); font-weight: 700; }
  .programa ol { margin: 1.25rem 0 .25rem; padding-left: 1.4rem; }
  .programa li { margin-bottom: .9rem; padding-left: .35rem; }
  .obra-linea { display: flex; justify-content: space-between; gap: 1rem; }
  .obra { font-weight: 650; }
  .autor { text-align: right; opacity: .72; }
  .programa small { display: block; margin-top: .2rem; opacity: .75; }
  .documentos { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 1.5rem; }
  .documentos a { padding: .55rem 1rem; color: var(--color-principal); border: 1px solid var(--color-principal); border-radius: 3px; font-size: .82rem; font-weight: 700; text-decoration: none; }
  .documentos a:hover { color: var(--color-blanco); background: var(--color-principal); }
  .historical-item { height: 100%; padding: clamp(1.4rem, 3vw, 1.8rem); background: #fff; border: 1px solid rgba(106,27,41,.12); border-radius: 8px; box-shadow: 0 12px 30px rgba(64,43,30,.05); }
  .historical-main { display: grid; grid-template-columns: minmax(0, 1fr) 150px; gap: 1.5rem; align-items: start; }
  .historical-main .poster-thumb { width: 150px; max-width: 150px; }
  .historical-main .poster-thumb img { width: 150px; max-width: 150px; height: auto; max-height: 210px; }
  .historical-item h3 { margin: .35rem 0; font-size: 1.2rem; }
  .historical-item p { margin: 0; opacity: .7; }
  .historical-item .programa { max-width: 850px; }
  .poster-dialog { width: min(92vw, 900px); max-height: 92vh; padding: 2.75rem 1rem 1rem; border: 0; border-radius: 6px; background: #fff; }
  .poster-dialog::backdrop { background: rgba(0,0,0,.78); }
  .poster-dialog img { display: block; max-width: 100%; max-height: calc(92vh - 4rem); margin: auto; object-fit: contain; }
  .poster-close { position: absolute; top: .45rem; right: .7rem; width: 2rem; height: 2rem; border: 0; background: transparent; color: #222; font-size: 1.8rem; line-height: 1; cursor: pointer; }
  .loading, .empty-state { padding: 2rem; text-align: center; background: var(--color-gris); border-radius: 4px; }
  .loading.error { color: #7a2525; }
  [hidden] { display: none !important; }
  @media (max-width: 900px) {
    .concert-list, .historical-list { grid-template-columns: 1fr; }
  }
  @media (max-width: 650px) {
    .agenda-page { padding-inline: 1rem; }
    .concert-card { grid-template-columns: 1fr; }
    .poster-thumb, .poster-thumb img,
    .historical-main .poster-thumb, .historical-main .poster-thumb img { width: 150px; max-width: 150px; }
    .historical-main { grid-template-columns: 1fr; }
    .obra-linea { display: block; }
    .autor { display: block; margin-top: .15rem; text-align: left; }
  }
</style>
